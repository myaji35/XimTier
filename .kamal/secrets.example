# Kamal secrets template — `cp .kamal/secrets.example .kamal/secrets` 후 채울 것.
# 이 example 파일만 git에 커밋. 실제 secrets는 .gitignore 적용.

# Rails 자격증명 — config/master.key 사용
RAILS_MASTER_KEY=$(cat config/master.key)

# GitHub Container Registry
# 1) GitHub Settings → Developer settings → Personal access tokens → Tokens (classic)
# 2) write:packages 스코프 부여 후 토큰 발급
KAMAL_REGISTRY_PASSWORD=${KAMAL_REGISTRY_PASSWORD:-CHANGE_ME}

# PostgreSQL accessory 비밀번호 (강력한 랜덤 문자열)
POSTGRES_PASSWORD=${POSTGRES_PASSWORD:-CHANGE_ME}
