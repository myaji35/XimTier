# Kamal secrets template — `cp .kamal/secrets.example .kamal/secrets` 후 채울 것.
# 이 example 파일만 git에 커밋. 실제 secrets는 .gitignore 적용.

# === 필수 ===
RAILS_MASTER_KEY=$(cat config/master.key)
KAMAL_REGISTRY_PASSWORD=$(gh auth token)

# === SMTP (선택, 미설정 시 :test 메일러로 폴백) ===
# 도메인 + SMTP 프로바이더 확정 후 다음 4개 채울 것
# Postmark 예:
#   SMTP_HOST=smtp.postmarkapp.com
#   SMTP_USERNAME=<server-api-token>
#   SMTP_PASSWORD=<server-api-token>  # Postmark는 동일
# Mailgun 예:
#   SMTP_HOST=smtp.mailgun.org
#   SMTP_USERNAME=postmaster@mg.YOUR_DOMAIN
#   SMTP_PASSWORD=<mailgun-smtp-password>
# AWS SES 예:
#   SMTP_HOST=email-smtp.ap-northeast-2.amazonaws.com
#   SMTP_USERNAME=<ses-smtp-username>
#   SMTP_PASSWORD=<ses-smtp-password>
SMTP_USERNAME=${SMTP_USERNAME:-}
SMTP_PASSWORD=${SMTP_PASSWORD:-}

# === Sentry (선택, DSN 없으면 자동 비활성) ===
SENTRY_DSN=${SENTRY_DSN:-}
