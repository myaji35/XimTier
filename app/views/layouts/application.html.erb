<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <% og_image_url = "#{ENV.fetch('APP_PROTOCOL', 'http')}://#{ENV.fetch('APP_HOST', request.host_with_port)}/og-image.png" %>
    <%= display_meta_tags(
          site: t("site.brand"),
          title: content_for(:title).presence || t("site.positioning"),
          reverse: true,
          separator: "—",
          description: t("site.positioning"),
          keywords: %w[XimTier Decision\ Intelligence Reverse\ What-If SHAP XAI Post-LLM EU\ AI\ Act],
          og: {
            type: "website",
            site_name: t("site.brand"),
            locale: I18n.locale.to_s,
            title: :title,
            description: :description,
            image: { _: og_image_url, width: 1200, height: 630, alt: t("site.positioning") }
          },
          twitter: { card: "summary_large_image", image: og_image_url }
        ) %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="XimTier">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#0B132D">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# hreflang (PRD §FR-1) %>
    <% I18n.available_locales.each do |loc| %>
      <link rel="alternate" hreflang="<%= loc %>" href="<%= request.base_url %>/<%= loc %>">
    <% end %>
    <link rel="alternate" hreflang="x-default" href="<%= request.base_url %>/">

    <%= yield :head %>

    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <%# JSON-LD 구조화 데이터 (SEO) %>
    <%= jsonld_script(organization_jsonld) %>
    <%= jsonld_script(website_jsonld) %>
    <%= yield :jsonld %>

    <%# Plausible Analytics — ENV PLAUSIBLE_DOMAIN 설정 시만 활성 %>
    <% if ENV["PLAUSIBLE_DOMAIN"].present? %>
      <script defer data-domain="<%= ENV['PLAUSIBLE_DOMAIN'] %>" src="https://plausible.io/js/script.js"></script>
    <% end %>
  </head>

  <body class="section-light">
    <%= render "shared/brand_svg_defs" %>

    <header class="nav-sticky">
      <div class="wrap flex items-center justify-between" style="height:68px;">
        <%= link_to home_path(locale: I18n.locale), class: "no-underline" do %>
          <%= render BrandLogoComponent.new(variant: :light, size: 28) %>
        <% end %>

        <nav class="hidden md:flex items-center" style="gap:30px;">
          <%= link_to t("site.nav.solution"),     solution_path(locale: I18n.locale), class: "text-[15px] font-medium text-[#475467] hover:text-[#0B132D] transition" %>
          <%= link_to t("site.nav.how_it_works"), how_it_works_path(locale: I18n.locale), class: "text-[15px] font-medium text-[#475467] hover:text-[#0B132D] transition" %>
          <%= link_to t("site.nav.use_cases"),    use_cases_path(locale: I18n.locale), class: "text-[15px] font-medium text-[#475467] hover:text-[#0B132D] transition" %>
          <%= link_to t("site.nav.pricing"),      pricing_path(locale: I18n.locale), class: "text-[15px] font-medium text-[#475467] hover:text-[#0B132D] transition" %>
          <%= link_to t("site.nav.market"),       market_path(locale: I18n.locale), class: "text-[15px] font-medium text-[#475467] hover:text-[#0B132D] transition" %>
          <%= link_to t("site.nav.team"),         team_path(locale: I18n.locale), class: "text-[15px] font-medium text-[#475467] hover:text-[#0B132D] transition" %>
        </nav>

        <div class="flex items-center" style="gap:10px;">
          <%= link_to t("site.nav.contact"), contact_path(locale: I18n.locale), class: "btn btn-ghost", style: "padding:9px 16px;font-size:13px;" %>
          <%= link_to t("site.nav.demo"),    demo_path(locale: I18n.locale),    class: "btn btn-primary", style: "padding:9px 18px;font-size:13px;" %>
          <span class="hidden md:inline text-[#e5e9f0]">|</span>
          <%= link_to "KO", home_path(locale: :ko), class: "text-[12px] font-semibold #{I18n.locale == :ko ? 'text-[#2563EB]' : 'text-[#697386] hover:text-[#0B132D]'} transition" %>
          <%= link_to "EN", home_path(locale: :en), class: "text-[12px] font-semibold #{I18n.locale == :en ? 'text-[#2563EB]' : 'text-[#697386] hover:text-[#0B132D]'} transition" %>
        </div>
      </div>
    </header>

    <main>
      <%= yield %>
    </main>

    <%= render "shared/tweaks_panel" %>

    <footer class="section-footer">
      <div class="wrap" style="padding-top:48px;padding-bottom:40px;">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
          <div>
            <%= render BrandLogoComponent.new(variant: :dark, size: 28) %>
            <p class="mt-3 text-[13px]" style="color:#a7b1c7;max-width:520px;">
              <%= t("site.positioning") %> · <%= t("site.product_label") %>
            </p>
          </div>
          <div class="font-mono text-[12px]" style="color:#697386;">
            build / 2026.05 · <%= t("site.footer.copyright") %>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
