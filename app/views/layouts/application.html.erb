<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || "#{t('site.name')} — #{t('site.tagline')}" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="XAISimTier">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="<%= t('site.tagline') %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# hreflang (PRD §FR-1) %>
    <% I18n.available_locales.each do |loc| %>
      <link rel="alternate" hreflang="<%= loc %>" href="<%= url_for(locale: loc, only_path: false) rescue request.original_url %>">
    <% end %>
    <link rel="alternate" hreflang="x-default" href="<%= request.base_url %>/">

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-950 text-slate-100 antialiased">
    <header class="border-b border-slate-800/60">
      <div class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
        <%= link_to home_path(locale: I18n.locale), class: "text-xl font-bold tracking-tight text-cyan-300" do %>
          <%= t("site.name") %>
        <% end %>
        <nav class="flex items-center gap-6 text-sm">
          <%= link_to t("site.nav.problem"),      "#problem",    class: "hover:text-cyan-300" %>
          <%= link_to t("site.nav.solution"),     "#solution",   class: "hover:text-cyan-300" %>
          <%= link_to t("site.nav.pricing"),      "#pricing",    class: "hover:text-cyan-300" %>
          <span class="text-slate-600">|</span>
          <%= link_to "한국어", home_path(locale: :ko), class: "#{I18n.locale == :ko ? 'text-cyan-300 font-semibold' : 'text-slate-400'}" %>
          <%= link_to "English", home_path(locale: :en), class: "#{I18n.locale == :en ? 'text-cyan-300 font-semibold' : 'text-slate-400'}" %>
        </nav>
      </div>
    </header>

    <main>
      <%= yield %>
    </main>

    <footer class="border-t border-slate-800/60 mt-24">
      <div class="max-w-6xl mx-auto px-6 py-8 text-sm text-slate-500">
        <%= t("site.footer.copyright") %>
      </div>
    </footer>
  </body>
</html>
