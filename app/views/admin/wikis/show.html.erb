<% s = @snapshot %>

<script>
  window.WIKI_COUNTS = {
    components: <%= s[:components].size %>,
    stimulus:   <%= s[:stimulus].size %>,
    controllers: <%= s[:controllers].size %>,
    models:     <%= s[:models].size %>,
    pages:      <%= s[:pages].size %>,
    locales:    <%= s[:locales].size %>,
    agents:     <%= s[:agents].size %>,
    issues:     <%= s[:issues][:available] ? s[:issues][:total] : 0 %>,
    research:   <%= (s[:research] || []).size %>
  };
</script>

<section id="overview" class="sec">
  <div class="stats">
    <div class="stat accent">
      <div class="l">실행 환경</div>
      <div class="v"><%= s[:stats][:env] %></div>
      <div class="sub">Rails <%= s[:stats][:rails] %> · Ruby <%= s[:stats][:ruby] %></div>
    </div>
    <div class="stat">
      <div class="l">Git</div>
      <div class="v" style="font-family:ui-monospace,Menlo,monospace;font-size:18px;"><%= s[:stats][:git_sha] || "—" %></div>
      <div class="sub">브랜치 <%= s[:stats][:git_branch] || "—" %></div>
    </div>
    <div class="stat">
      <div class="l">앱 파일</div>
      <div class="v"><%= s[:stats][:total_files] %></div>
      <div class="sub">app/ 하위 전체</div>
    </div>
    <div class="stat">
      <div class="l">하네스 이슈</div>
      <% if s[:issues][:available] %>
        <div class="v"><%= s[:issues][:total] %></div>
        <div class="sub">
          <% (s[:issues][:by_status] || {}).each do |k, v| %>
            <%= k %>: <strong><%= v %></strong>&nbsp;
          <% end %>
        </div>
      <% else %>
        <div class="v" style="color:#94A3B8;">—</div>
        <div class="sub">레지스트리 없음</div>
      <% end %>
    </div>
  </div>
</section>

<section id="components" class="sec">
  <h2>🧩 뷰 컴포넌트 <span class="cnt">(<%= s[:components].size %>) — 화면 조립 단위</span></h2>
  <div class="grid cols-3">
    <% s[:components].each do |c| %>
      <div class="item">
        <div class="name"><%= c[:name] %></div>
        <div class="file"><%= c[:file] %></div>
        <div class="meta"><%= c[:lines] %>줄 · 템플릿 <%= c[:has_template] ? "✓" : "✗" %></div>
      </div>
    <% end %>
  </div>
</section>

<section id="stimulus" class="sec">
  <h2>⚡ Stimulus 컨트롤러 <span class="cnt">(<%= s[:stimulus].size %>) — 화면 인터랙션</span></h2>
  <div class="grid cols-2">
    <% s[:stimulus].each do |c| %>
      <div class="item">
        <div class="sti">data-controller="<%= c[:identifier] %>"</div>
        <div class="file"><%= c[:file] %></div>
        <div class="meta"><%= c[:lines] %>줄</div>
      </div>
    <% end %>
  </div>
</section>

<section id="controllers" class="sec">
  <h2>🎮 Rails 컨트롤러 <span class="cnt">(<%= s[:controllers].size %>) — 요청 라우팅 + 비즈니스 로직</span></h2>
  <div class="grid cols-2">
    <% s[:controllers].each do |c| %>
      <div class="item">
        <div class="name"><%= c[:name] %></div>
        <div class="file"><%= c[:file] %></div>
        <div class="meta"><%= c[:lines] %>줄</div>
      </div>
    <% end %>
  </div>
</section>

<section id="models" class="sec">
  <h2>💾 데이터 모델 <span class="cnt">(<%= s[:models].size %>) — DB 테이블 매핑</span></h2>
  <div class="grid cols-3">
    <% s[:models].each do |m| %>
      <div class="item">
        <div class="name"><%= m[:name] %></div>
        <div class="meta"><%= m[:lines] %>줄</div>
      </div>
    <% end %>
  </div>
</section>

<section id="pages" class="sec">
  <h2>📄 페이지 <span class="cnt">(<%= s[:pages].size %>) — 마케팅 + 컨버전 화면</span></h2>
  <div class="grid cols-4">
    <% s[:pages].each do |p| %>
      <div class="item">
        <div class="name"><%= p[:name] %></div>
        <div class="meta"><%= p[:lines] %>줄</div>
      </div>
    <% end %>
  </div>
</section>

<section id="locales" class="sec">
  <h2>🌐 다국어 사전 <span class="cnt">(<%= s[:locales].size %>) — 한/영 문구</span></h2>
  <div class="grid cols-2">
    <% s[:locales].each do |loc| %>
      <div class="locale">
        <div class="hdr">
          <span class="code"><%= loc[:locale] %></span>
          <span style="font-size:11px;color:#6B7280;">파일 <%= loc[:file_count] %>개 · 키 약 <%= loc[:approx_keys] %>개</span>
        </div>
        <div class="files">
          <% loc[:files].each do |f| %>
            <span><%= f %></span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>

<section id="agents" class="sec">
  <h2>🤖 하네스 에이전트 <span class="cnt">(<%= s[:agents].size %>) — 자율 실행 LLM 역할</span></h2>
  <% if s[:agents].empty? %>
    <p class="empty">.claude/agents 디렉터리가 비어 있습니다.</p>
  <% else %>
    <div class="grid cols-4">
      <% s[:agents].each do |a| %>
        <div class="item">
          <div class="sti"><%= a[:name] %></div>
          <div class="meta">파일 크기 <%= a[:size_kb] %> KB</div>
        </div>
      <% end %>
    </div>
  <% end %>
</section>

<section id="issues" class="sec">
  <h2>📋 하네스 이슈
    <span class="cnt">
      <% if s[:issues][:available] %>(<%= s[:issues][:total] %>) — 진행 상태 + 우선순위<% end %>
    </span>
  </h2>
  <% if s[:issues][:available] %>
    <div class="grid cols-4" style="margin-bottom:14px;">
      <% (s[:issues][:by_priority] || {}).each do |p, c| %>
        <div class="item">
          <div class="meta">우선순위 <%= p %></div>
          <div class="name" style="font-size:22px;margin-top:4px;"><%= c %>건</div>
        </div>
      <% end %>
    </div>

    <% if s[:issues][:latest].any? %>
      <table>
        <thead>
          <tr>
            <th>이슈 ID</th>
            <th>제목</th>
            <th>상태</th>
            <th>우선순위</th>
          </tr>
        </thead>
        <tbody>
          <% s[:issues][:latest].each do |iss| %>
            <tr>
              <td class="id"><%= iss[:id] %></td>
              <td><%= iss[:title] %></td>
              <td><%= iss[:status] %></td>
              <td style="font-family:ui-monospace,Menlo,monospace;color:#6B7280;"><%= iss[:priority] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>

    <p style="margin-top:14px;font-size:12px;color:#6B7280;">
      💡 누적 학습 패턴 <strong><%= s[:issues][:success_patterns] %>개</strong>가 다음 작업에 자동 반영됩니다.
    </p>
  <% else %>
    <p class="empty">이슈 레지스트리(.claude/issue-db/registry.json)를 찾을 수 없습니다.</p>
  <% end %>
</section>

<section id="reports" class="sec">
  <h2>📑 보고서 라이브러리 <span class="cnt">(<%= (@reports || []).size %>) — IR · 컴플라이언스 · 전략 PDF/HTML</span></h2>
  <% if (@reports || []).empty? %>
    <p class="empty">config/reports.yml 또는 storage/reports/ 디렉터리가 비어 있습니다.</p>
  <% else %>
    <div class="grid cols-2">
      <% @reports.each do |r| %>
        <div class="item" style="padding:14px 16px;">
          <div style="display:flex;justify-content:space-between;align-items:baseline;gap:8px;margin-bottom:6px;">
            <div class="name" style="font-size:14px;">
              <%= link_to r["title"], admin_wiki_report_path(slug: r["slug"]),
                          style: "color:#0B132D;text-decoration:none;" %>
            </div>
            <span style="background:#F3F4F6;color:#475467;font-size:10px;padding:2px 7px;border-radius:4px;font-family:ui-monospace,Menlo,monospace;letter-spacing:.05em;">
              <%= r["category"] %>
            </span>
          </div>
          <div class="meta" style="margin-bottom:6px;color:#6B7280;font-size:11px;">
            <%= r["subtitle"] %>
          </div>
          <div class="meta" style="font-size:11px;color:#94A3B8;display:flex;flex-wrap:wrap;gap:10px;">
            <span>👥 <%= r["audience"] %></span>
            <span>📄 <%= r["pages"] %>p</span>
            <span>📦 PDF <%= r["pdf_size_kb"] %>KB</span>
            <span>📅 <%= r["created_at"] %></span>
            <% if r["updated_at"] %>
              <span style="color:#2563EB;">⟳ <%= r["updated_at"].strftime("%Y-%m-%d %H:%M") %></span>
            <% end %>
          </div>
          <p style="margin:8px 0 10px;font-size:11.5px;color:#475467;line-height:1.5;">
            <%= r["summary"] %>
          </p>
          <div style="display:flex;gap:6px;flex-wrap:wrap;">
            <% if r["has_html"] %>
              <%= link_to "🔍 HTML 보기", admin_wiki_report_path(slug: r["slug"]),
                  style: "background:#2563EB;color:#fff;font-size:11px;padding:5px 10px;border-radius:5px;font-weight:600;" %>
            <% end %>
            <% if r["has_pdf"] %>
              <%= link_to "📄 PDF 열기", admin_wiki_report_pdf_path(slug: r["slug"], format: :pdf),
                  target: "_blank",
                  style: "background:#fff;border:1px solid #2563EB;color:#2563EB;font-size:11px;padding:5px 10px;border-radius:5px;font-weight:600;" %>
              <%= link_to "⬇ PDF 다운로드", admin_wiki_report_pdf_path(slug: r["slug"], download: 1, format: :pdf),
                  style: "background:#fff;border:1px solid #E5E7EB;color:#475467;font-size:11px;padding:5px 10px;border-radius:5px;" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
    <p style="margin-top:12px;font-size:11px;color:#94A3B8;">
      💡 새 보고서는 <code style="background:#F3F4F6;padding:1px 5px;border-radius:3px;">storage/reports/{slug}.html</code>·<code style="background:#F3F4F6;padding:1px 5px;border-radius:3px;">{slug}.pdf</code> 쌍으로 두고 <code style="background:#F3F4F6;padding:1px 5px;border-radius:3px;">config/reports.yml</code>에 메타데이터를 추가하면 자동으로 노출됩니다.
    </p>
  <% end %>
</section>

<section id="research" class="sec">
  <h2>📚 리서치 라이브러리 <span class="cnt">(<%= (s[:research] || []).size %>) — 시장 조사 + 경쟁사 분석</span></h2>
  <% if (s[:research] || []).empty? %>
    <p class="empty">_workspace/research 디렉터리가 비어 있습니다.</p>
  <% else %>
    <div class="grid cols-2">
      <% s[:research].each do |doc| %>
        <div class="item" style="padding:14px 16px;">
          <div class="name" style="font-size:14px;"><%= doc[:name] %></div>
          <div class="file"><%= doc[:file] %></div>
          <div class="meta"><%= doc[:lines] %>줄 · <%= doc[:size_kb] %> KB</div>
          <% if doc[:headings].any? %>
            <ul style="margin:8px 0 0; padding-left:16px; font-size:11px; color:#475467; line-height:1.6;">
              <% doc[:headings].each do |h| %>
                <li style="list-style:disc;"><%= h.sub(/^#+\s*/, "") %></li>
              <% end %>
            </ul>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</section>
