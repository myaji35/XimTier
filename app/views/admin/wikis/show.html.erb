<% s = @snapshot %>

<script>
  window.WIKI_COUNTS = {
    components: <%= s[:components].size %>,
    stimulus:   <%= s[:stimulus].size %>,
    controllers: <%= s[:controllers].size %>,
    models:     <%= s[:models].size %>,
    pages:      <%= s[:pages].size %>,
    locales:    <%= s[:locales].size %>,
    agents:     <%= s[:agents].size %>,
    issues:     <%= s[:issues][:available] ? s[:issues][:total] : 0 %>,
    reports:    <%= (@reports || []).size %>,
    research:   <%= (s[:research] || []).size %>
  };
</script>

<section id="overview" class="sec">
  <div class="stats">
    <div class="stat accent">
      <div class="l">실행 환경</div>
      <div class="v"><%= s[:stats][:env] %></div>
      <div class="sub">Rails <%= s[:stats][:rails] %> · Ruby <%= s[:stats][:ruby] %></div>
    </div>
    <div class="stat">
      <div class="l">Git</div>
      <div class="v" style="font-family:ui-monospace,Menlo,monospace;font-size:18px;"><%= s[:stats][:git_sha] || "—" %></div>
      <div class="sub">브랜치 <%= s[:stats][:git_branch] || "—" %></div>
    </div>
    <div class="stat">
      <div class="l">앱 파일</div>
      <div class="v"><%= s[:stats][:total_files] %></div>
      <div class="sub">app/ 하위 전체</div>
    </div>
    <div class="stat">
      <div class="l">하네스 이슈</div>
      <% if s[:issues][:available] %>
        <div class="v"><%= s[:issues][:total] %></div>
        <div class="sub">
          <% (s[:issues][:by_status] || {}).each do |k, v| %>
            <%= k %>: <strong><%= v %></strong>&nbsp;
          <% end %>
        </div>
      <% else %>
        <div class="v" style="color:#94A3B8;">—</div>
        <div class="sub">레지스트리 없음</div>
      <% end %>
    </div>
  </div>
</section>

<section id="components" class="sec">
  <h2><span class="hico"><svg><use href="#ico-components"/></svg></span>뷰 컴포넌트 <span class="cnt">(<%= s[:components].size %>) — 화면 조립 단위</span></h2>
  <div class="grid cols-3">
    <% s[:components].each do |c| %>
      <div class="item">
        <div class="name"><%= c[:name] %></div>
        <div class="file"><%= c[:file] %></div>
        <div class="meta"><%= c[:lines] %>줄 · 템플릿 <%= c[:has_template] ? "✓" : "✗" %></div>
      </div>
    <% end %>
  </div>
</section>

<section id="stimulus" class="sec">
  <h2><span class="hico"><svg><use href="#ico-stimulus"/></svg></span>Stimulus 컨트롤러 <span class="cnt">(<%= s[:stimulus].size %>) — 화면 인터랙션</span></h2>
  <div class="grid cols-2">
    <% s[:stimulus].each do |c| %>
      <div class="item">
        <div class="sti">data-controller="<%= c[:identifier] %>"</div>
        <div class="file"><%= c[:file] %></div>
        <div class="meta"><%= c[:lines] %>줄</div>
      </div>
    <% end %>
  </div>
</section>

<section id="controllers" class="sec">
  <h2><span class="hico"><svg><use href="#ico-controllers"/></svg></span>Rails 컨트롤러 <span class="cnt">(<%= s[:controllers].size %>) — 요청 라우팅 + 비즈니스 로직</span></h2>
  <div class="grid cols-2">
    <% s[:controllers].each do |c| %>
      <div class="item">
        <div class="name"><%= c[:name] %></div>
        <div class="file"><%= c[:file] %></div>
        <div class="meta"><%= c[:lines] %>줄</div>
      </div>
    <% end %>
  </div>
</section>

<section id="models" class="sec">
  <h2><span class="hico"><svg><use href="#ico-models"/></svg></span>데이터 모델 <span class="cnt">(<%= s[:models].size %>) — DB 테이블 매핑</span></h2>
  <div class="grid cols-3">
    <% s[:models].each do |m| %>
      <div class="item">
        <div class="name"><%= m[:name] %></div>
        <div class="meta"><%= m[:lines] %>줄</div>
      </div>
    <% end %>
  </div>
</section>

<section id="pages" class="sec">
  <h2><span class="hico"><svg><use href="#ico-pages"/></svg></span>페이지 <span class="cnt">(<%= s[:pages].size %>) — 마케팅 + 컨버전 화면</span></h2>
  <div class="grid cols-4">
    <% s[:pages].each do |p| %>
      <div class="item">
        <div class="name"><%= p[:name] %></div>
        <div class="meta"><%= p[:lines] %>줄</div>
      </div>
    <% end %>
  </div>
</section>

<section id="locales" class="sec">
  <h2><span class="hico"><svg><use href="#ico-locales"/></svg></span>다국어 사전 <span class="cnt">(<%= s[:locales].size %>) — 한/영 문구</span></h2>
  <div class="grid cols-2">
    <% s[:locales].each do |loc| %>
      <div class="locale">
        <div class="hdr">
          <span class="code"><%= loc[:locale] %></span>
          <span style="font-size:11px;color:#6B7280;">파일 <%= loc[:file_count] %>개 · 키 약 <%= loc[:approx_keys] %>개</span>
        </div>
        <div class="files">
          <% loc[:files].each do |f| %>
            <span><%= f %></span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>

<section id="agents" class="sec">
  <h2><span class="hico"><svg><use href="#ico-agents"/></svg></span>하네스 에이전트 <span class="cnt">(<%= s[:agents].size %>) — 자율 실행 LLM 역할</span></h2>
  <% if s[:agents].empty? %>
    <p class="empty">.claude/agents 디렉터리가 비어 있습니다.</p>
  <% else %>
    <div class="grid cols-4">
      <% s[:agents].each do |a| %>
        <div class="item">
          <div class="sti"><%= a[:name] %></div>
          <div class="meta">파일 크기 <%= a[:size_kb] %> KB</div>
        </div>
      <% end %>
    </div>
  <% end %>
</section>

<section id="issues" class="sec">
  <h2><span class="hico"><svg><use href="#ico-issues"/></svg></span>하네스 이슈
    <span class="cnt">
      <% if s[:issues][:available] %>(<%= s[:issues][:total] %>) — 진행 상태 + 우선순위<% end %>
    </span>
  </h2>
  <% if s[:issues][:available] %>
    <div class="grid cols-4" style="margin-bottom:14px;">
      <% (s[:issues][:by_priority] || {}).each do |p, c| %>
        <div class="item">
          <div class="meta">우선순위 <%= p %></div>
          <div class="name" style="font-size:22px;margin-top:4px;"><%= c %>건</div>
        </div>
      <% end %>
    </div>

    <% if s[:issues][:latest].any? %>
      <table>
        <thead>
          <tr>
            <th>이슈 ID</th>
            <th>제목</th>
            <th>상태</th>
            <th>우선순위</th>
          </tr>
        </thead>
        <tbody>
          <% s[:issues][:latest].each do |iss| %>
            <tr>
              <td class="id"><%= iss[:id] %></td>
              <td><%= iss[:title] %></td>
              <td><%= iss[:status] %></td>
              <td style="font-family:ui-monospace,Menlo,monospace;color:#6B7280;"><%= iss[:priority] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>

    <p style="margin-top:14px;font-size:12px;color:#6B7280;">
      누적 학습 패턴 <strong><%= s[:issues][:success_patterns] %>개</strong>가 다음 작업에 자동 반영됩니다.
    </p>
  <% else %>
    <p class="empty">이슈 레지스트리(.claude/issue-db/registry.json)를 찾을 수 없습니다.</p>
  <% end %>
</section>

<section id="roadmap" class="sec">
  <h2 style="display:flex;justify-content:space-between;align-items:center;">
    <span style="display:flex;align-items:center;gap:8px;">
      <span class="hico"><svg><use href="#ico-controllers"/></svg></span>
      인가·시장 진출 로드맵
      <span class="cnt">— 법인·규제·제품·시장·투자·운영 통합 간트</span>
    </span>
    <% if @roadmap %>
      <button id="rm-edit-toggle" type="button"
              style="background:#2563EB;color:#fff;font-size:11px;padding:5px 12px;border-radius:5px;font-weight:600;border:none;cursor:pointer;">
        ✎ 편집 모드
      </button>
    <% end %>
  </h2>
  <% if @roadmap.nil? %>
    <p class="empty">config/roadmap.yml 이 없거나 비어 있습니다.</p>
  <% else %>
    <% months = @roadmap["months"] %>
    <% total = months.length %>
    <% range_start = @roadmap["range_start"] %>
    <% reports_by_slug = (@reports || []).index_by { |r| r["slug"] } %>
    <style>
      .gantt{background:#fff;border:1px solid #E5E7EB;border-radius:8px;overflow:hidden;font-size:11px;}
      .gantt .gantt-head{display:grid;grid-template-columns:200px 1fr;background:#F9FAFB;border-bottom:2px solid #2563EB;}
      .gantt .gantt-head .track-head{padding:8px 12px;font-weight:600;color:#374151;text-transform:uppercase;letter-spacing:.05em;font-size:10px;}
      .gantt .gantt-head .months-head{display:grid;}
      .gantt .gantt-head .month-cell{padding:6px 4px;text-align:center;font-size:9.5px;color:#6B7280;border-left:1px solid #F0F0F0;font-family:ui-monospace,Menlo,monospace;}
      .gantt .gantt-head .month-cell.qstart{background:#F3F4F6;color:#16325C;font-weight:600;}
      .gantt .gantt-track{display:grid;grid-template-columns:200px 1fr;border-bottom:1px solid #F3F4F6;}
      .gantt .gantt-track:last-child{border-bottom:none;}
      .gantt .track-label{padding:10px 12px;background:#FAFAFA;border-right:1px solid #E5E7EB;display:flex;align-items:center;gap:8px;}
      .gantt .track-label .dot{width:10px;height:10px;border-radius:3px;flex-shrink:0;}
      .gantt .track-label .name{font-weight:600;color:#16325C;font-size:12px;}
      .gantt .track-label .count{font-size:10px;color:#94A3B8;}
      .gantt .phases-grid{position:relative;}
      .gantt .phase-row{position:relative;height:32px;border-bottom:1px solid #F8F9FA;}
      .gantt .phase-row:last-child{border-bottom:none;}
      .gantt .grid-bg{position:absolute;inset:0;display:grid;pointer-events:none;}
      .gantt .grid-bg .gb-cell{border-left:1px solid #F3F4F6;}
      .gantt .grid-bg .gb-cell.qstart{border-left:1px solid #E5E7EB;}
      .gantt .phase-bar{position:absolute;top:5px;bottom:5px;border-radius:4px;display:flex;align-items:center;
                        padding:0 8px;font-size:10px;color:#fff;font-weight:600;cursor:pointer;
                        text-decoration:none;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;
                        transition:transform .1s, box-shadow .1s;}
      .gantt .phase-bar:hover{transform:scale(1.01);box-shadow:0 4px 12px -4px rgba(0,0,0,0.3);z-index:2;}
      .gantt .phase-bar.done{opacity:.65;}
      .gantt .phase-bar.planned{opacity:.85;}
      .gantt .phase-bar.in_progress::before{content:"▶";font-size:8px;margin-right:4px;}
      .gantt .phase-bar.blocked{background:repeating-linear-gradient(45deg,#EF4444,#EF4444 6px,#F87171 6px,#F87171 12px) !important;}
      .gantt .phase-tip{position:absolute;display:none;background:#0B132D;color:#fff;font-size:10.5px;padding:6px 10px;
                        border-radius:4px;z-index:50;box-shadow:0 6px 18px -4px rgba(0,0,0,0.3);max-width:260px;line-height:1.5;}
      .gantt .legend{display:flex;gap:14px;padding:8px 12px;background:#F9FAFB;border-top:1px solid #E5E7EB;font-size:10.5px;color:#6B7280;flex-wrap:wrap;}
      .gantt .legend .ll{display:flex;align-items:center;gap:5px;}
      .gantt .legend .ll .sw{width:14px;height:10px;border-radius:2px;}
      .gantt .today-line{position:absolute;top:0;bottom:0;width:2px;background:#EF4444;z-index:3;pointer-events:none;}
      .gantt .today-line::after{content:"오늘";position:absolute;top:2px;left:4px;background:#EF4444;color:#fff;
                                font-size:9px;padding:1px 5px;border-radius:2px;font-weight:600;}
      .gantt-foot{padding:8px 12px;background:#F9FAFB;font-size:10.5px;color:#6B7280;border-top:1px solid #E5E7EB;}
    </style>

    <div class="gantt">
      <%# Header — 월 눈금 %>
      <div class="gantt-head">
        <div class="track-head">트랙 / Phase</div>
        <div class="months-head" style="grid-template-columns: repeat(<%= total %>, 1fr);">
          <% months.each do |m| %>
            <div class="month-cell <%= 'qstart' if [1,4,7,10].include?(m.month) %>">
              <%= m.strftime("%y/%m") %>
            </div>
          <% end %>
        </div>
      </div>

      <%# Tracks %>
      <% @roadmap["tracks"].each do |track| %>
        <div class="gantt-track">
          <div class="track-label">
            <span class="dot" style="background:<%= track['color'] || '#2563EB' %>;"></span>
            <div>
              <div class="name"><%= track["title"] %></div>
              <div class="count"><%= (track["phases"] || []).size %>개 단계</div>
            </div>
          </div>
          <div class="phases-grid">
            <%# 배경 격자 + 오늘선 %>
            <% today = Date.today %>
            <% today_offset_pct = (((today - range_start).to_i / 30.4) / total.to_f * 100).clamp(0, 100) %>
            <% (track["phases"] || []).each_with_index do |phase, _idx| %>
              <div class="phase-row">
                <div class="grid-bg" style="grid-template-columns: repeat(<%= total %>, 1fr);">
                  <% months.each do |m| %>
                    <div class="gb-cell <%= 'qstart' if [1,4,7,10].include?(m.month) %>"></div>
                  <% end %>
                </div>
                <%
                  ps = parse_month_view(phase["start"])
                  pe = parse_month_view(phase["end"])
                  next unless ps && pe
                  start_offset = ((ps.year * 12 + ps.month) - (range_start.year * 12 + range_start.month))
                  dur_months   = ((pe.year * 12 + pe.month) - (ps.year * 12 + ps.month) + 1)
                  left_pct  = (start_offset.to_f / total) * 100
                  width_pct = (dur_months.to_f / total) * 100
                  matched_reports = (phase["reports"] || []).map { |s| reports_by_slug[s] }.compact
                  first_report = matched_reports.first
                  bar_href = if first_report
                    if first_report["has_html"]
                      admin_wiki_report_path(slug: first_report["slug"])
                    elsif first_report["has_pdf"]
                      admin_wiki_report_pdf_path(slug: first_report["slug"])
                    end
                  end
                  tooltip = [
                    phase["title"],
                    "기간: #{phase['start']} → #{phase['end']} (#{dur_months}개월)",
                    "상태: #{phase['status']}",
                    "담당: #{phase['owner']}",
                    "🎯 #{phase['milestone']}",
                    (matched_reports.any? ? "📄 #{matched_reports.map{|r|r['title']}.join(' · ')}" : nil)
                  ].compact.join(" • ")
                %>
                <% if bar_href %>
                  <a class="phase-bar <%= phase['status'] %>"
                     style="left:<%= left_pct.round(2) %>%; width:<%= width_pct.round(2) %>%; background:<%= track['color'] || '#2563EB' %>;"
                     href="<%= bar_href %>"
                     title="<%= tooltip %>">
                    <%= phase["title"] %>
                    <% if matched_reports.any? %><span style="margin-left:auto;font-size:9px;opacity:.85;">[<%= matched_reports.size %>]</span><% end %>
                  </a>
                <% else %>
                  <div class="phase-bar <%= phase['status'] %>"
                       style="left:<%= left_pct.round(2) %>%; width:<%= width_pct.round(2) %>%; background:<%= track['color'] || '#2563EB' %>; cursor:default;"
                       title="<%= tooltip %>">
                    <%= phase["title"] %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# 범례 %>
      <div class="legend">
        <span class="ll"><span class="sw" style="background:#2563EB;"></span>계획됨 (planned)</span>
        <span class="ll"><span class="sw" style="background:#2563EB;opacity:1;"></span>진행 중 (in_progress) — ▶ 표시</span>
        <span class="ll"><span class="sw" style="background:#2563EB;opacity:.65;"></span>완료 (done)</span>
        <span class="ll"><span class="sw" style="background:repeating-linear-gradient(45deg,#EF4444,#EF4444 4px,#F87171 4px,#F87171 8px);"></span>차단 (blocked)</span>
        <span class="ll" style="margin-left:auto;color:#94A3B8;">📄 막대 클릭 → 연결된 보고서 열림 · [숫자] = 연결 보고서 수</span>
      </div>

      <div class="gantt-foot">
        일정 변경은 <code style="background:#F3F4F6;padding:1px 5px;border-radius:3px;">config/roadmap.yml</code> 만 수정하면 자동 반영. 각 phase의 <code>reports:</code> 배열에 보고서 slug 추가 시 막대 클릭으로 보고서 직접 열람 가능. 또는 위의 <strong>✎ 편집 모드</strong> 버튼으로 화면에서 직접 편집 가능.
      </div>
    </div>

    <%# ───────────────── 편집기 ───────────────── %>
    <div id="rm-editor" style="display:none;margin-top:14px;background:#0B132D;color:#e6e8f0;border-radius:8px;padding:16px;">
      <style>
        #rm-editor h3{color:#fff;font-size:13px;margin:14px 0 8px;border-bottom:1px solid rgba(255,255,255,0.15);padding-bottom:5px;letter-spacing:.01em;}
        #rm-editor h3:first-child{margin-top:0;}
        #rm-editor label{font-size:10px;color:#a7b1c7;text-transform:uppercase;letter-spacing:.08em;display:block;margin-bottom:3px;}
        #rm-editor input[type="text"],#rm-editor input[type="month"],#rm-editor select,#rm-editor textarea{
          width:100%;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);color:#fff;
          font-family:inherit;font-size:11px;padding:5px 8px;border-radius:4px;outline:none;
        }
        #rm-editor input:focus,#rm-editor select:focus,#rm-editor textarea:focus{border-color:#00C8C8;background:rgba(0,200,200,0.06);}
        #rm-editor input[type="color"]{width:32px;height:24px;border:1px solid rgba(255,255,255,0.12);border-radius:4px;background:transparent;cursor:pointer;}
        #rm-editor .rm-row{display:grid;gap:8px;align-items:end;}
        #rm-editor .rm-range{grid-template-columns:1fr 1fr;}
        #rm-editor .track-card{background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:6px;padding:12px;margin-bottom:12px;}
        #rm-editor .track-head{display:grid;grid-template-columns:auto 1fr 1fr 90px;gap:8px;align-items:end;margin-bottom:10px;}
        #rm-editor .phase-row{display:grid;grid-template-columns:1.5fr 0.9fr 0.9fr 1fr 1fr 1fr 1.6fr 28px;gap:6px;align-items:start;
                              padding:6px 0;border-top:1px dashed rgba(255,255,255,0.08);}
        #rm-editor .phase-row:first-of-type{border-top:none;}
        #rm-editor .phase-row .small-label{font-size:9px;color:#697386;}
        #rm-editor .btn{background:#2563EB;color:#fff;font-size:11px;padding:5px 10px;border-radius:4px;font-weight:600;
                        border:none;cursor:pointer;}
        #rm-editor .btn.subtle{background:rgba(255,255,255,0.06);color:#a7b1c7;}
        #rm-editor .btn.danger{background:#EF4444;}
        #rm-editor .btn.ghost{background:transparent;border:1px solid rgba(255,255,255,0.15);}
        #rm-editor .btn:hover{filter:brightness(1.1);}
        #rm-editor .btn-icon{background:rgba(239,68,68,0.15);color:#FCA5A5;font-size:13px;width:28px;height:28px;
                             border-radius:4px;border:none;cursor:pointer;line-height:1;}
        #rm-editor .btn-icon:hover{background:rgba(239,68,68,0.35);}
        #rm-editor .actions-bar{display:flex;gap:8px;flex-wrap:wrap;padding:12px 0;border-top:1px solid rgba(255,255,255,0.15);
                                margin-top:14px;align-items:center;}
        #rm-editor .actions-bar .status{flex:1;font-size:11px;color:#a7b1c7;}
        #rm-editor .actions-bar .status.success{color:#10B981;}
        #rm-editor .actions-bar .status.error{color:#EF4444;}
        #rm-editor select option{background:#0B132D;color:#fff;}
      </style>

      <h3>🛠 로드맵 편집기 — config/roadmap.yml 직접 수정</h3>

      <div class="rm-row rm-range" style="margin-bottom:10px;">
        <div>
          <label>표시 시작 (range.start)</label>
          <input type="month" id="rm-range-start" value="<%= @roadmap['range_start'].strftime('%Y-%m') %>">
        </div>
        <div>
          <label>표시 끝 (range.end)</label>
          <input type="month" id="rm-range-end" value="<%= @roadmap['range_end'].strftime('%Y-%m') %>">
        </div>
      </div>

      <h3>트랙 (가로 줄)</h3>
      <div id="rm-tracks"></div>

      <button type="button" id="rm-add-track" class="btn ghost" style="margin-top:6px;">+ 새 트랙 추가</button>

      <div class="actions-bar">
        <button type="button" id="rm-save" class="btn">💾 저장</button>
        <button type="button" id="rm-reset" class="btn subtle">↺ 변경 취소</button>
        <span class="status" id="rm-status">변경 후 저장하면 config/roadmap.yml에 즉시 기록 (백업 자동 생성)</span>
      </div>

      <details style="margin-top:14px;font-size:10.5px;color:#697386;">
        <summary style="cursor:pointer;color:#a7b1c7;">📋 사용 가능한 보고서 slug (reports 필드)</summary>
        <pre style="background:rgba(255,255,255,0.03);padding:10px;border-radius:4px;margin-top:6px;overflow-x:auto;font-family:ui-monospace,Menlo,monospace;font-size:10px;color:#cbd5e1;"><% (@reports || []).each do |r| %><%= r['slug'].ljust(28) %> <%= r['title'] %>
<% end %></pre>
      </details>
    </div>

    <script>
    (function(){
      // 초기 데이터 — 서버에서 직렬화
      var INITIAL_ROADMAP = <%= raw({
        range: { start: @roadmap['range_start'].strftime('%Y-%m'), end: @roadmap['range_end'].strftime('%Y-%m') },
        tracks: @roadmap['tracks']
      }.to_json) %>;

      var state = JSON.parse(JSON.stringify(INITIAL_ROADMAP));
      var statusEl = document.getElementById('rm-status');
      var editorEl = document.getElementById('rm-editor');
      var toggleBtn = document.getElementById('rm-edit-toggle');

      // 토글
      toggleBtn.addEventListener('click', function(){
        var visible = editorEl.style.display !== 'none';
        editorEl.style.display = visible ? 'none' : 'block';
        toggleBtn.textContent = visible ? '✎ 편집 모드' : '× 편집 닫기';
        if (!visible) {
          render();
          editorEl.scrollIntoView({behavior:'smooth', block:'start'});
        }
      });

      function setStatus(msg, cls){
        statusEl.textContent = msg;
        statusEl.className = 'status ' + (cls || '');
      }

      function escapeHtml(s){ return String(s||'').replace(/[&<>"']/g, function(c){
        return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
      });}

      function render(){
        var container = document.getElementById('rm-tracks');
        container.innerHTML = '';
        state.tracks.forEach(function(t, ti){
          var card = document.createElement('div');
          card.className = 'track-card';
          card.innerHTML = '' +
            '<div class="track-head">' +
              '<div><label>색상</label><input type="color" data-track-color="'+ti+'" value="'+escapeHtml(t.color||'#2563EB')+'"></div>' +
              '<div><label>트랙 ID (영문)</label><input type="text" data-track-id="'+ti+'" value="'+escapeHtml(t.id||'')+'"></div>' +
              '<div><label>제목</label><input type="text" data-track-title="'+ti+'" value="'+escapeHtml(t.title||'')+'"></div>' +
              '<button type="button" class="btn danger" data-del-track="'+ti+'">트랙 삭제</button>' +
            '</div>' +
            '<div data-phases-for="'+ti+'"></div>' +
            '<button type="button" class="btn ghost" data-add-phase="'+ti+'" style="margin-top:6px;">+ phase 추가</button>';
          container.appendChild(card);

          var phasesEl = card.querySelector('[data-phases-for]');
          (t.phases || []).forEach(function(p, pi){
            var row = document.createElement('div');
            row.className = 'phase-row';
            row.innerHTML = '' +
              '<div><label class="small-label">제목</label><input type="text" data-p="title" data-ti="'+ti+'" data-pi="'+pi+'" value="'+escapeHtml(p.title||'')+'"></div>' +
              '<div><label class="small-label">시작</label><input type="month" data-p="start" data-ti="'+ti+'" data-pi="'+pi+'" value="'+escapeHtml(p.start||'')+'"></div>' +
              '<div><label class="small-label">종료</label><input type="month" data-p="end" data-ti="'+ti+'" data-pi="'+pi+'" value="'+escapeHtml(p.end||'')+'"></div>' +
              '<div><label class="small-label">상태</label>' +
                '<select data-p="status" data-ti="'+ti+'" data-pi="'+pi+'">' +
                  ['planned','in_progress','done','blocked'].map(function(s){
                    return '<option value="'+s+'"'+(p.status===s?' selected':'')+'>'+s+'</option>';
                  }).join('') +
                '</select>' +
              '</div>' +
              '<div><label class="small-label">담당</label><input type="text" data-p="owner" data-ti="'+ti+'" data-pi="'+pi+'" value="'+escapeHtml(p.owner||'')+'"></div>' +
              '<div><label class="small-label">phase ID</label><input type="text" data-p="id" data-ti="'+ti+'" data-pi="'+pi+'" value="'+escapeHtml(p.id||'')+'"></div>' +
              '<div><label class="small-label">보고서 slug (콤마 구분)</label><input type="text" data-p="reports" data-ti="'+ti+'" data-pi="'+pi+'" value="'+escapeHtml((p.reports||[]).join(', '))+'" placeholder="예: ir_preseed, tam_81b_evidence"></div>' +
              '<button type="button" class="btn-icon" data-del-phase="'+ti+':'+pi+'" title="phase 삭제">×</button>';
            phasesEl.appendChild(row);

            // milestone(별도 줄)
            var ms = document.createElement('div');
            ms.style.gridColumn = '1 / -1';
            ms.style.marginTop = '-2px';
            ms.innerHTML = '<label class="small-label">마일스톤(달성 기준)</label><input type="text" data-p="milestone" data-ti="'+ti+'" data-pi="'+pi+'" value="'+escapeHtml(p.milestone||'')+'">';
            phasesEl.appendChild(ms);
          });
        });

        bindInputs();
      }

      function bindInputs(){
        // 트랙 필드
        editorEl.querySelectorAll('[data-track-id]').forEach(function(el){
          el.oninput = function(){ state.tracks[+el.dataset.trackId].id = el.value.trim(); };
        });
        editorEl.querySelectorAll('[data-track-title]').forEach(function(el){
          el.oninput = function(){ state.tracks[+el.dataset.trackTitle].title = el.value; };
        });
        editorEl.querySelectorAll('[data-track-color]').forEach(function(el){
          el.oninput = function(){ state.tracks[+el.dataset.trackColor].color = el.value; };
        });

        // phase 필드
        editorEl.querySelectorAll('[data-ti][data-pi]').forEach(function(el){
          el.oninput = el.onchange = function(){
            var ti = +el.dataset.ti, pi = +el.dataset.pi, key = el.dataset.p;
            var v = el.value;
            if (key === 'reports') {
              v = v.split(',').map(function(s){return s.trim();}).filter(Boolean);
            }
            state.tracks[ti].phases[pi][key] = v;
          };
        });

        // 트랙 삭제
        editorEl.querySelectorAll('[data-del-track]').forEach(function(b){
          b.onclick = function(){
            var ti = +b.dataset.delTrack;
            if (!confirm('트랙 "'+state.tracks[ti].title+'" 삭제? 안의 phase도 모두 삭제됩니다.')) return;
            state.tracks.splice(ti,1); render();
          };
        });
        // phase 추가
        editorEl.querySelectorAll('[data-add-phase]').forEach(function(b){
          b.onclick = function(){
            var ti = +b.dataset.addPhase;
            var rs = document.getElementById('rm-range-start').value;
            state.tracks[ti].phases = state.tracks[ti].phases || [];
            state.tracks[ti].phases.push({
              id: 'new_'+Date.now().toString(36).slice(-4),
              title: '새 단계', start: rs, end: rs,
              status: 'planned', owner: '', reports: [], milestone: ''
            });
            render();
          };
        });
        // phase 삭제
        editorEl.querySelectorAll('[data-del-phase]').forEach(function(b){
          b.onclick = function(){
            var parts = b.dataset.delPhase.split(':');
            var ti = +parts[0], pi = +parts[1];
            state.tracks[ti].phases.splice(pi,1); render();
          };
        });
      }

      // 새 트랙
      document.getElementById('rm-add-track').addEventListener('click', function(){
        state.tracks.push({
          id: 'new_track_'+Date.now().toString(36).slice(-4),
          title: '새 트랙', color: '#2563EB', phases: []
        });
        render();
      });

      // 변경 취소
      document.getElementById('rm-reset').addEventListener('click', function(){
        if (!confirm('편집 중인 모든 변경을 취소하고 마지막 저장 상태로 돌립니다.')) return;
        state = JSON.parse(JSON.stringify(INITIAL_ROADMAP));
        render();
        setStatus('변경 취소됨.');
      });

      // 저장
      document.getElementById('rm-save').addEventListener('click', function(){
        var payload = {
          range: {
            start: document.getElementById('rm-range-start').value,
            end:   document.getElementById('rm-range-end').value
          },
          tracks: state.tracks
        };
        setStatus('저장 중...');
        fetch('<%= admin_wiki_update_roadmap_path %>', {
          method: 'POST',
          headers: {'Content-Type':'application/json','Accept':'application/json'},
          body: JSON.stringify(payload),
          credentials: 'include'
        }).then(function(r){ return r.json().then(function(j){ return {ok:r.ok, body:j}; }); })
          .then(function(res){
            if (res.ok && res.body.ok) {
              setStatus('✓ 저장 완료 ('+res.body.saved_at+') — 새로고침하면 간트가 갱신됩니다.', 'success');
              setTimeout(function(){ location.reload(); }, 800);
            } else {
              var msg = (res.body.errors || [res.body.error || '저장 실패']).join(' / ');
              setStatus('✗ ' + msg, 'error');
            }
          })
          .catch(function(e){ setStatus('✗ 네트워크 오류: '+e.message, 'error'); });
      });

      // 초기 렌더
      render();
    })();
    </script>
    <%# ───────────────── /편집기 ───────────────── %>
  <% end %>
</section>

<section id="reports" class="sec">
  <h2><span class="hico"><svg><use href="#ico-reports"/></svg></span>보고서 라이브러리 <span class="cnt">(<%= (@reports || []).size %>) — IR · 컴플라이언스 · 전략 PDF/HTML</span></h2>
  <% if (@reports || []).empty? %>
    <p class="empty">config/reports.yml 또는 storage/reports/ 디렉터리가 비어 있습니다.</p>
  <% else %>
    <style>
      .report-card{display:block;background:#fff;border:1px solid #E5E7EB;border-radius:8px;padding:14px 16px;
                   color:inherit;text-decoration:none;transition:border-color .15s, box-shadow .15s, transform .05s;
                   position:relative;}
      .report-card:hover{border-color:#2563EB;box-shadow:0 6px 18px -8px rgba(37,99,235,0.25);}
      .report-card:active{transform:translateY(1px);}
      .report-card .rc-row1{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:6px;}
      .report-card .rc-title{font-size:14px;font-weight:600;color:#0B132D;line-height:1.35;}
      .report-card .rc-cat{background:#F3F4F6;color:#475467;font-size:10px;padding:2px 7px;border-radius:4px;
                           font-family:ui-monospace,Menlo,monospace;letter-spacing:.05em;flex-shrink:0;}
      .report-card .rc-sub{margin-bottom:6px;color:#6B7280;font-size:11px;}
      .report-card .rc-meta{font-size:11px;color:#94A3B8;display:flex;flex-wrap:wrap;gap:12px;align-items:center;}
      .report-card .rc-summary{margin:8px 0 10px;font-size:11.5px;color:#475467;line-height:1.5;}
      .report-card .rc-actions{display:flex;gap:6px;flex-wrap:wrap;}
      .report-card .rc-btn{font-size:11px;padding:5px 12px;border-radius:5px;text-decoration:none;font-weight:600;
                           display:inline-flex;align-items:center;gap:5px;border:1px solid transparent;}
      .report-card .rc-btn.primary{background:#2563EB;color:#fff;}
      .report-card .rc-btn.outline{background:#fff;border-color:#2563EB;color:#2563EB;}
      .report-card .rc-btn.subtle{background:#fff;border-color:#E5E7EB;color:#475467;font-weight:500;}
      .report-card .rc-btn:hover{filter:brightness(1.05);}
    </style>
    <div class="grid cols-2">
      <% @reports.each do |r| %>
        <% primary_url = r["has_html"] ? admin_wiki_report_path(slug: r["slug"]) :
                                          (r["has_pdf"] ? admin_wiki_report_pdf_path(slug: r["slug"]) : "#") %>
        <% primary_target = (!r["has_html"] && r["has_pdf"]) ? "_blank" : nil %>
        <a href="<%= primary_url %>" <%= "target=\"#{primary_target}\"".html_safe if primary_target %> class="report-card">
          <div class="rc-row1">
            <div class="rc-title"><%= r["title"] %></div>
            <span class="rc-cat"><%= r["category"] %></span>
          </div>
          <div class="rc-sub"><%= r["subtitle"] %></div>
          <div class="rc-meta">
            <span><%= r["audience"] %></span>
            <% if r["pages"].present? %><span><%= r["pages"] %>p</span><% end %>
            <span>PDF <%= r["pdf_size_kb"] %>KB</span>
            <span><%= r["created_at"] %></span>
            <% if r["updated_at"] %>
              <span style="color:#2563EB;">⟳ <%= r["updated_at"].strftime("%Y-%m-%d %H:%M") %></span>
            <% end %>
          </div>
          <p class="rc-summary"><%= r["summary"] %></p>
          <div class="rc-actions" onclick="event.stopPropagation()">
            <% if r["has_html"] %>
              <%= link_to "HTML 보기", admin_wiki_report_path(slug: r["slug"]),
                  class: "rc-btn primary", data: { "stop-propagation": "true" } %>
            <% end %>
            <% if r["has_pdf"] %>
              <%= link_to "PDF 열기", admin_wiki_report_pdf_path(slug: r["slug"]),
                  target: "_blank", class: "rc-btn outline" %>
              <%= link_to "PDF 다운로드", admin_wiki_report_pdf_path(slug: r["slug"], download: 1),
                  class: "rc-btn subtle" %>
            <% end %>
          </div>
        </a>
      <% end %>
    </div>
    <script>
      // 카드 안 액션 버튼 클릭은 카드의 메인 링크와 분리
      document.querySelectorAll('.report-card .rc-actions a').forEach(function(a){
        a.addEventListener('click', function(e){ e.stopPropagation(); });
      });
    </script>
    <p style="margin-top:12px;font-size:11px;color:#94A3B8;">
      새 보고서는 <code style="background:#F3F4F6;padding:1px 5px;border-radius:3px;">config/reports_data/{slug}.html</code>·<code style="background:#F3F4F6;padding:1px 5px;border-radius:3px;">{slug}.pdf</code> 쌍으로 두고 <code style="background:#F3F4F6;padding:1px 5px;border-radius:3px;">config/reports.yml</code>에 메타데이터를 추가하면 자동으로 노출됩니다.
    </p>
  <% end %>
</section>

<section id="research" class="sec">
  <h2><span class="hico"><svg><use href="#ico-research"/></svg></span>리서치 라이브러리 <span class="cnt">(<%= (s[:research] || []).size %>) — 시장 조사 + 경쟁사 분석</span></h2>
  <% if (s[:research] || []).empty? %>
    <p class="empty">_workspace/research 디렉터리가 비어 있습니다.</p>
  <% else %>
    <div class="grid cols-2">
      <% s[:research].each do |doc| %>
        <div class="item" style="padding:14px 16px;">
          <div class="name" style="font-size:14px;"><%= doc[:name] %></div>
          <div class="file"><%= doc[:file] %></div>
          <div class="meta"><%= doc[:lines] %>줄 · <%= doc[:size_kb] %> KB</div>
          <% if doc[:headings].any? %>
            <ul style="margin:8px 0 0; padding-left:16px; font-size:11px; color:#475467; line-height:1.6;">
              <% doc[:headings].each do |h| %>
                <li style="list-style:disc;"><%= h.sub(/^#+\s*/, "") %></li>
              <% end %>
            </ul>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</section>
