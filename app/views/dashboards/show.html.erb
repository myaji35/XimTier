<% content_for :title, "#{t('dashboard.title')} — #{t('site.brand')}" %>

<section class="section-tinted section-pad">
  <div class="wrap" style="max-width:960px;">
    <div class="flex items-center justify-between flex-wrap gap-4 mb-8">
      <div>
        <div class="eyebrow"><span class="dot"></span>DASHBOARD</div>
        <h1 class="h-section mt-3"><%= t("dashboard.title") %></h1>
        <p class="lead mt-3" style="color:#475467;"><%= t("dashboard.welcome", name: current_user.display_name) %></p>
      </div>
      <%= button_to t("dashboard.sign_out"), destroy_user_session_path, method: :delete, class: "btn btn-ghost", form: { style: "display:inline-block;" }, data: { turbo: false } %>
    </div>

    <% if flash[:notice] %>
      <div class="mb-6 p-4 rounded-[14px]" style="background:#E0F2FE;border:1px solid #0891B2;color:#0E7490;"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="mb-6 p-4 rounded-[14px]" style="background:#FEF2F2;border:1px solid #FCA5A5;color:#991B1B;"><%= flash[:alert] %></div>
    <% end %>

    <% if @demo_requests.empty? %>
      <div class="card text-center" style="padding:48px;">
        <p style="color:#697386;"><%= t("dashboard.no_requests") %></p>
        <div class="mt-6">
          <%= link_to t("site.hero.cta_demo"), demo_path(locale: I18n.locale), class: "btn btn-grad" %>
        </div>
      </div>
    <% else %>
      <div class="space-y-6">
        <% @demo_requests.each do |dr| %>
          <article class="card" style="padding:28px;">
            <div class="flex items-center justify-between flex-wrap gap-3">
              <div class="font-mono text-[11px]" style="color:#697386;letter-spacing:0.14em;">
                #<%= format('%04d', dr.id) %> · <%= t("dashboard.requested_at") %> <%= l(dr.created_at, format: :long) rescue dr.created_at.to_s %>
              </div>
              <% status_color = { "pending" => "#F59E0B", "scheduled" => "#2563EB", "completed" => "#10B981", "cancelled" => "#94A3B8" }[dr.status] %>
              <span class="font-mono text-[11px] px-3 py-1 rounded-full" style="background:<%= status_color %>20;color:<%= status_color %>;letter-spacing:0.1em;">
                <%= t("dashboard.status.#{dr.status}") %>
              </span>
            </div>

            <% if dr.preferred_at %>
              <div class="mt-4 text-[14px]" style="color:#475467;"><strong style="color:#0B132D;"><%= t("dashboard.preferred_at") %>:</strong> <%= l(dr.preferred_at, format: :long) rescue dr.preferred_at.to_s %></div>
            <% end %>

            <% if dr.meeting_url.present? %>
              <div class="mt-3 p-3 rounded-[10px]" style="background:linear-gradient(135deg,rgba(37,99,235,0.08),rgba(0,200,200,0.08));border:1px solid #2563EB30;">
                <span style="color:#0B132D;font-weight:500;"><%= t("dashboard.meeting_url") %>:</span>
                <a href="<%= dr.meeting_url %>" target="_blank" style="color:#2563EB;text-decoration:underline;margin-left:8px;"><%= dr.meeting_url %></a>
              </div>
            <% end %>

            <div class="mt-5">
              <div class="text-[13px] font-medium mb-2" style="color:#697386;"><%= t("dashboard.description") %></div>
              <p style="color:#475467;line-height:1.6;"><%= simple_format(dr.data_description) %></p>
            </div>

            <% if dr.data_file.attached? %>
              <div class="mt-4 text-[13px]" style="color:#475467;">
                <%= t("dashboard.file") %>: <%= link_to dr.data_file.filename, rails_blob_path(dr.data_file, disposition: "attachment"), style: "color:#2563EB;" %>
              </div>
            <% end %>

            <%# Comments thread %>
            <div class="mt-6 pt-5" style="border-top:1px solid #e5e9f0;">
              <div class="text-[13px] font-medium mb-3" style="color:#697386;"><%= t("dashboard.comments") %></div>

              <% dr.comments.recent.each do |c| %>
                <div class="mb-3 p-3 rounded-[10px]" style="background:<%= c.by_admin ? '#F2F4F7' : '#fff' %>;border:1px solid #e5e9f0;">
                  <div class="font-mono text-[11px] mb-1" style="color:<%= c.by_admin ? '#2563EB' : '#697386' %>;">
                    <%= c.by_admin ? "XimTier 팀" : (c.user.display_name) %> · <%= l(c.created_at, format: :short) rescue c.created_at.strftime('%Y-%m-%d %H:%M') %>
                  </div>
                  <div class="text-[14px]" style="color:#0B132D;"><%= simple_format(c.body) %></div>
                </div>
              <% end %>

              <%= form_with url: demo_request_comments_path(demo_request_id: dr.id, locale: I18n.locale), method: :post, local: true, class: "mt-3" do |f| %>
                <textarea name="comment[body]" required rows="2" placeholder="<%= t('dashboard.comment_placeholder') %>" class="w-full px-3 py-2 rounded-[8px] border text-[14px]" style="border-color:#e5e9f0;background:#fff;color:#0B132D;"></textarea>
                <div class="mt-2 text-right">
                  <button type="submit" class="btn btn-primary" style="border:0;cursor:pointer;padding:8px 16px;font-size:13px;"><%= t("dashboard.add_comment") %></button>
                </div>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
