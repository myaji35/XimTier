<% content_for :title, "#{t('pricing.h1')} — #{t('site.brand')}" %>

<section class="surface-canvas section-pad">
  <div class="wrap">
    <p class="type-uppercase-tag text-rausch"><%= t("pricing.eyebrow") %></p>
    <h1 class="type-display-xl mt-3" style="max-width:920px;"><%= t("pricing.h1") %></h1>
    <p class="type-body-md text-body-airbnb mt-5" style="max-width:760px;"><%= t("pricing.lead") %></p>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4" style="gap:20px;">
      <% %w[light industry vibe platform].each_with_index do |key, i| %>
        <% tier = t("pricing.tiers.#{key}") %>
        <% is_platform = key == "platform" %>
        <article class="card-airbnb shadow-card-hover relative" style="padding:28px; <%= 'border-color: var(--color-rausch);' if is_platform %>">
          <% if is_platform && tier[:soon] %>
            <div class="absolute top-4 right-4 airbnb-new-tag">
              <%= tier[:soon].upcase %>
            </div>
          <% end %>

          <div class="font-mono type-uppercase-tag text-muted-airbnb">
            TIER / <%= tier[:badge] %>
          </div>
          <h3 class="type-display-sm mt-3"><%= tier[:name] %></h3>
          <div class="mt-4 type-title-md text-rausch" style="font-size:18px;"><%= tier[:price] %></div>
          <p class="type-body-sm text-body-airbnb mt-4" style="line-height:1.6;"><%= tier[:desc] %></p>

          <div class="mt-6 pt-5 border-t-hairline">
            <% if is_platform %>
              <%= link_to t("site.nav.contact"), contact_path(locale: I18n.locale), class: "btn-secondary-airbnb", style: "width:100%;" %>
            <% else %>
              <%= link_to t("site.hero.cta_demo"), demo_path(locale: I18n.locale),
                    class: "btn-rausch",
                    style: "width:100%;" %>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
  </div>
</section>

<%# Feature Comparison Matrix %>
<section class="surface-soft section-pad">
  <div class="wrap" style="max-width:1100px;">
    <p class="type-uppercase-tag text-rausch">FEATURE MATRIX</p>
    <h2 class="type-display-xl mt-3"><%= t("pricing.matrix_title") %></h2>

    <div class="mt-10 overflow-x-auto">
      <table class="w-full card-airbnb" style="border-collapse:separate; border-spacing:0; min-width:760px; padding:0; overflow:hidden;">
        <thead>
          <tr>
            <% [["FEATURE", "text-muted-airbnb"], ["① LIGHT", "text-muted-airbnb"], ["② INDUSTRY", "text-rausch"], ["③ VIBE", "text-rausch"], ["④ PLATFORM", "text-rausch"]].each_with_index do |(label, klass), i| %>
              <th class="<%= i == 0 ? 'text-left' : 'text-center' %> p-4 font-mono type-uppercase-tag <%= klass %> border-b-hairline" style="background: var(--color-surface-soft); font-size:11px; letter-spacing:0.14em;"><%= label %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% t("pricing.matrix_features").each_with_index do |row, i| %>
            <% is_last = i == t("pricing.matrix_features").size - 1 %>
            <% bb_class = is_last ? "" : "border-b-hairline" %>
            <tr>
              <td class="p-4 type-body-sm text-ink-airbnb <%= bb_class %>"><%= row[:feature] %></td>
              <% %i[light industry vibe platform].each do |tier| %>
                <% val = row[tier] %>
                <% cls = val == "✓" ? "text-rausch font-bold" : (val == "—" ? "text-muted-airbnb" : "text-body-airbnb") %>
                <td class="p-4 text-center <%= bb_class %>">
                  <span class="<%= cls %>" style="font-size:<%= val.to_s.length > 1 ? '12px' : '16px' %>;"><%= val %></span>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<%# ARR Roadmap %>
<section class="surface-canvas section-pad-compact">
  <div class="wrap">
    <p class="type-uppercase-tag text-rausch">ARR ROADMAP</p>
    <h2 class="type-display-xl mt-3" style="max-width:760px;"><%= t("pricing.roadmap_title") %></h2>

    <div class="mt-10 grid grid-cols-2 md:grid-cols-4" style="gap:16px;">
      <% t("pricing.roadmap").each do |r| %>
        <div class="card-airbnb shadow-card-hover" style="padding:20px;">
          <div class="font-mono type-display-sm text-rausch" style="font-size:20px;"><%= r[:year] %></div>
          <div class="mt-2 type-body-sm text-body-airbnb"><%= r[:goal] %></div>
        </div>
      <% end %>
    </div>
  </div>
</section>
