<% content_for :title, "#{t('vision.h1')} — #{t('site.brand')}" %>

<section class="section-dark section-pad">
  <div class="wrap">
    <div class="eyebrow"><span class="dot"></span><%= t("vision.eyebrow") %></div>
    <h1 class="h-section mt-3" style="color:#fff; max-width:920px;"><%= t("vision.h1") %></h1>
    <p class="lead mt-5" style="color:#a7b1c7; max-width:760px;"><%= t("vision.lead") %></p>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-3" style="gap:20px;">
      <% %w[one two three].each_with_index do |key, i| %>
        <% p = t("vision.phases.#{key}") %>
        <article class="card-dark" style="padding:32px;">
          <div class="font-mono text-[11px]" style="color:#00C8C8; letter-spacing:0.14em;">
            PHASE / <%= format('%02d', i + 1) %>
          </div>
          <div class="mt-2 font-mono text-[12px]" style="color:#8a94ac;"><%= p[:years] %></div>
          <h3 class="h-card mt-4" style="color:#fff;"><%= p[:title] %></h3>
          <div class="mt-1 text-[13px] italic" style="color:#00C8C8;"><%= p[:analogy] %></div>
          <p class="mt-4 text-[14px]" style="color:#a7b1c7; line-height:1.65;"><%= p[:body] %></p>

          <div class="mt-6 pt-5" style="border-top:1px solid rgba(255,255,255,0.08);">
            <div class="flex items-baseline justify-between">
              <div class="text-[12px]" style="color:#8a94ac;">실현 가능성</div>
              <div class="text-[20px] font-bold text-brand-grad"><%= p[:feasibility] %>%</div>
            </div>
            <div class="mt-2 w-full" style="height:6px; background:rgba(255,255,255,0.08); border-radius:999px; overflow:hidden;">
              <div style="height:100%; width:<%= p[:feasibility] %>%; background:linear-gradient(90deg,#2563EB,#00C8C8);"></div>
            </div>
            <div class="mt-3 text-[12px]" style="color:#8a94ac;">매출 잠재력: <span style="color:#e6e8f0;"><%= p[:revenue] %></span></div>
          </div>
        </article>
      <% end %>
    </div>
  </div>
</section>

<%# Annual roadmap %>
<section class="section-light section-pad">
  <div class="wrap">
    <div class="eyebrow"><span class="dot"></span>ROADMAP</div>
    <h2 class="h-section mt-3" style="max-width:760px;"><%= t("vision.roadmap_title") %></h2>

    <div class="mt-12 space-y-3">
      <% t("vision.roadmap").each do |row| %>
        <div class="grid grid-cols-[100px_1fr] gap-6 items-center p-5 rounded-[14px]" style="background:#F2F4F7; border:1px solid #e5e9f0;">
          <div class="font-mono text-[20px] font-bold text-brand-grad"><%= row[:year] %></div>
          <div class="text-[15px]" style="color:#0B132D;"><%= row[:goal] %></div>
        </div>
      <% end %>
    </div>
  </div>
</section>
