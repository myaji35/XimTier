<% content_for :title, "#{@case[:title]} — #{t('site.brand')}" %>
<% content_for :jsonld do %>
  <%= jsonld_script(article_jsonld(
        title: @case[:title],
        description: "#{@case[:persona]} · #{@case[:industry_label]}"
      )) %>
<% end %>

<%# 01 Hero (Canvas) %>
<section class="surface-canvas section-pad">
  <div class="wrap" style="max-width:920px;">
    <p class="type-uppercase-tag text-rausch"><%= @case[:eyebrow] %></p>
    <h1 class="type-display-xl mt-3"><%= @case[:title] %></h1>
    <div class="mt-6 grid grid-cols-1 md:grid-cols-3" style="gap:16px;">
      <div class="font-mono type-body-sm">
        <div class="type-uppercase-tag text-rausch">// PERSONA</div>
        <div class="mt-1 text-ink-airbnb"><%= @case[:persona] %></div>
      </div>
      <div class="font-mono type-body-sm">
        <div class="type-uppercase-tag text-rausch">// INDUSTRY</div>
        <div class="mt-1 text-ink-airbnb"><%= @case[:industry_label] %></div>
      </div>
      <div class="font-mono type-body-sm">
        <div class="type-uppercase-tag text-rausch">// DATASET</div>
        <div class="mt-1 text-ink-airbnb"><%= @case[:dataset] %></div>
      </div>
    </div>
  </div>
</section>

<%# 02 Problem (Canvas, 2-col with case visual on right) %>
<section class="surface-soft section-pad">
  <div class="wrap grid grid-cols-1 md:grid-cols-[1fr_1fr] items-center" style="gap:64px;">
    <div>
      <p class="type-uppercase-tag text-rausch">PROBLEM</p>
      <h2 class="type-display-xl mt-3"><%= @case[:problem_title] %></h2>
      <p class="type-body-md text-body-airbnb mt-5"><%= @case[:problem_body] %></p>
    </div>
    <div class="case-visual">
      <%= render "shared/case_visual_#{@case_key}_problem" rescue render("shared/case_visual_fallback") %>
    </div>
  </div>
</section>

<%# 03 Approach (Canvas, 2-col with case visual on right) %>
<section class="surface-canvas section-pad">
  <div class="wrap grid grid-cols-1 md:grid-cols-[1fr_1fr] items-center" style="gap:64px;">
    <div>
      <p class="type-uppercase-tag text-rausch">APPROACH</p>
      <h2 class="type-display-xl mt-3"><%= @case[:approach_title] %></h2>
      <p class="type-body-md text-body-airbnb mt-5"><%= @case[:approach_body] %></p>
    </div>
    <div class="case-visual">
      <%= render "shared/case_visual_#{@case_key}_approach" rescue render("shared/case_visual_fallback") %>
    </div>
  </div>
</section>

<%# 04 Variables table (Manufacturing only) %>
<% if @case[:variables].present? %>
  <section class="surface-soft section-pad">
    <div class="wrap" style="max-width:920px;">
      <p class="type-uppercase-tag text-rausch">VARIABLES</p>
      <h2 class="type-display-xl mt-3"><%= @case[:variables_title] %></h2>

      <div class="mt-10 overflow-x-auto">
        <table class="w-full card-airbnb" style="border-collapse:separate; border-spacing:0; min-width:560px; padding:0; overflow:hidden;">
          <thead>
            <tr>
              <% [["VARIABLE", "text-muted-airbnb"], ["BASELINE", "text-muted-airbnb"], ["OPTIMAL", "text-rausch"], ["Δ", "text-rausch"]].each do |label, klass| %>
                <th class="text-left p-4 font-mono type-uppercase-tag <%= klass %> border-b-hairline" style="background: var(--color-surface-soft); font-size:11px; letter-spacing:0.14em;"><%= label %></th>
              <% end %>
            </tr>
          </thead>
          <tbody>
            <% @case[:variables].each_with_index do |v, i| %>
              <% is_last = i == @case[:variables].size - 1 %>
              <% bb = is_last ? "" : "border-b-hairline" %>
              <tr>
                <td class="p-4 type-body-md text-ink-airbnb <%= bb %>" style="background: var(--color-canvas);"><%= v[:name] %></td>
                <td class="p-4 font-mono type-body-sm text-muted-airbnb <%= bb %>" style="background: var(--color-canvas);"><%= v[:from] %></td>
                <td class="p-4 font-mono type-body-sm text-rausch font-semibold <%= bb %>" style="background: var(--color-canvas);"><%= v[:to] %></td>
                <td class="p-4 font-mono type-body-sm text-rausch <%= bb %>" style="background: var(--color-canvas);"><%= v[:delta] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div class="mt-6 text-center">
        <%= link_to (I18n.locale == :ko ? "라이브 데모에서 직접 슬라이더 조작하기 →" : "Try the live demo →"),
              how_it_works_path(locale: I18n.locale, anchor: "reverse-what-if-demo"),
              class: "type-body-sm font-semibold text-rausch hover:underline" %>
      </div>
    </div>
  </section>
<% end %>

<%# 05 Outcomes (Canvas) %>
<section class="surface-canvas section-pad">
  <div class="wrap" style="max-width:920px;">
    <p class="type-uppercase-tag text-rausch">OUTCOMES</p>
    <h2 class="type-display-xl mt-3"><%= @case[:outcomes_title] %></h2>

    <div class="mt-10 grid grid-cols-1 md:grid-cols-2" style="gap:16px;">
      <% @case[:outcomes].each_with_index do |o, i| %>
        <div class="card-airbnb shadow-card-hover" style="padding:24px;">
          <div class="font-mono type-uppercase-tag text-rausch">OUT / <%= format('%02d', i + 1) %></div>
          <p class="type-body-md text-ink-airbnb mt-3" style="line-height:1.6;"><%= o %></p>
        </div>
      <% end %>
    </div>

    <div class="mt-8 p-3 rounded-[10px] text-center border-hairline-soft" style="background: var(--color-surface-soft);">
      <span class="font-mono type-uppercase-tag text-muted-airbnb">⚠ <%= @case[:note] %></span>
    </div>
  </div>
</section>

<%# 06 CTA (Canvas) %>
<section class="surface-soft section-pad-compact text-center">
  <div class="wrap">
    <h2 class="type-display-xl" style="max-width:760px; margin:0 auto;"><%= t("cases_cta.title") %></h2>
    <p class="type-body-md text-body-airbnb mt-4"><%= t("cases_cta.body") %></p>
    <div class="mt-8 flex justify-center flex-wrap" style="gap:12px;">
      <%= link_to t("cases_cta.button"), demo_path(locale: I18n.locale), class: "btn-rausch" %>
      <%= link_to t("site.nav.contact"), contact_path(locale: I18n.locale), class: "btn-secondary-airbnb" %>
    </div>
  </div>
</section>
