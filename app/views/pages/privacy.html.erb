<% content_for :title, "#{t('privacy_page.h1')} — #{t('site.brand')}" %>

<section class="section-light section-pad">
  <div class="wrap" style="max-width:760px;">
    <div class="eyebrow"><span class="dot"></span><%= t("privacy_page.eyebrow") %></div>
    <h1 class="h-section mt-3"><%= t("privacy_page.h1") %></h1>
    <p class="lead mt-5" style="color:#475467;"><%= t("privacy_page.lead") %></p>

    <div class="mt-12 space-y-8">
      <% t("privacy_page.sections").each do |s| %>
        <article>
          <h2 class="text-[20px] font-semibold mb-3" style="color:#0B132D;"><%= s[:title] %></h2>
          <div class="text-[14px]" style="color:#475467; line-height:1.75; white-space:pre-line;"><%= s[:body] %></div>
        </article>
      <% end %>
    </div>
  </div>
</section>
