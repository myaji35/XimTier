<% content_for :title, "#{t('solution.workflow_title')} — #{t('site.brand')}" %>

<section class="section-light section-pad">
  <div class="wrap">
    <div class="eyebrow"><span class="dot"></span><%= t("site.nav.how_it_works") %></div>
    <h1 class="h-section mt-3" style="max-width:920px;"><%= t("solution.workflow_title") %></h1>
    <p class="lead mt-5" style="color:#475467; max-width:760px;">
      <%= I18n.locale == :ko ?
            "데이터 탐색부터 AI Q&A까지 — 5단계가 한 자리에서 끝납니다. 비전문가도 5분 안에 결론에 도달합니다." :
            "From data exploration to AI Q&A — 5 steps in one place. Even non-experts reach a conclusion in 5 minutes." %>
    </p>

    <div class="mt-14">
      <%= render WorkflowStepsComponent.new(steps: t("workflow.steps"), tone: :light) %>
    </div>
  </div>
</section>

<%# ============ Live Reverse What-If Demo ============ %>
<section id="reverse-what-if-demo" class="section-tinted section-pad">
  <div class="wrap">
    <div class="eyebrow"><span class="dot"></span><%= t("reverse_what_if.section_eyebrow") %></div>
    <h2 class="h-section mt-3" style="max-width:920px;"><%= t("reverse_what_if.section_title") %></h2>
    <p class="lead mt-5" style="color:#475467; max-width:760px;"><%= t("reverse_what_if.section_lead") %></p>

    <div class="mt-12">
      <%= render "shared/reverse_what_if_demo" %>
    </div>
  </div>
</section>

<%# Step detail blocks %>
<section class="section-tinted section-pad">
  <div class="wrap space-y-8">
    <% t("workflow.steps").each_with_index do |step, i| %>
      <% is_core = step[:sub].to_s.include?("★") %>
      <div class="grid grid-cols-1 md:grid-cols-[80px_1fr] gap-6" style="padding:36px; background:#fff; border-radius:18px; border:1.5px solid <%= is_core ? '#2563EB' : '#e5e9f0' %>;">
        <div class="font-mono text-[14px]" style="color:<%= is_core ? '#2563EB' : '#697386' %>; letter-spacing:0.12em;">
          STEP / <%= format('%02d', i + 1) %>
        </div>
        <div>
          <div class="flex items-baseline gap-3 flex-wrap">
            <h3 class="h-card" style="color:#0B132D;"><%= step[:title] %></h3>
            <div class="font-mono text-[12px]" style="color:<%= is_core ? '#00C8C8' : '#697386' %>;"><%= step[:sub] %></div>
          </div>
          <p class="mt-3" style="color:#475467; line-height:1.65;"><%= step[:desc] %></p>
        </div>
      </div>
    <% end %>
  </div>
</section>

<section class="section-dark section-pad-compact text-center">
  <div class="wrap">
    <h2 class="h-section" style="color:#fff; max-width:760px; margin:0 auto;">
      <%= I18n.locale == :ko ? "지금 5단계를 직접 체험해보세요." : "Experience the 5 steps yourself." %>
    </h2>
    <div class="mt-8">
      <%= link_to t("site.hero.cta_demo"), demo_path(locale: I18n.locale), class: "btn btn-grad" %>
    </div>
  </div>
</section>
