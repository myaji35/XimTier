<% content_for :title, "#{t('solution.workflow_title')} — #{t('site.brand')}" %>
<% content_for :description, (I18n.locale == :ko ?
     "데이터 탐색 → 통계 분석 → Reverse What-If → 자동 보고서 → AI Q&A. XimTier 5단계 워크플로우와 도입 검토 시 자주 묻는 질문 6가지를 한 자리에 정리." :
     "Data exploration → statistics → Reverse What-If → auto-report → AI Q&A. The XimTier 5-step workflow with the six questions teams most often ask before deployment.") %>
<% faq_items = t("faq.items", default: []) %>
<% if faq_items.is_a?(Array) && faq_items.any? %>
  <% content_for :jsonld do %>
    <%= jsonld_script(faqpage_jsonld(faq_items.map { |it| [it[:q], it[:a]] })) %>
  <% end %>
<% end %>

<section class="surface-canvas section-pad">
  <div class="wrap">
    <p class="type-uppercase-tag text-rausch"><%= t("site.nav.how_it_works") %></p>
    <h1 class="type-display-xl mt-3" style="max-width:920px;"><%= t("solution.workflow_title") %></h1>
    <p class="type-body-md text-body-airbnb mt-5" style="max-width:760px;">
      <%= I18n.locale == :ko ?
            "데이터 탐색부터 AI Q&A까지 — 5단계가 한 자리에서 끝납니다. 비전문가도 5분 안에 결론에 도달합니다." :
            "From data exploration to AI Q&A — 5 steps in one place. Even non-experts reach a conclusion in 5 minutes." %>
    </p>

    <div class="mt-14">
      <%= render WorkflowStepsComponent.new(steps: t("workflow.steps"), tone: :light) %>
    </div>
  </div>
</section>

<%# ============ Live Reverse What-If Demo ============ %>
<section id="reverse-what-if-demo" class="surface-soft section-pad">
  <div class="wrap">
    <p class="type-uppercase-tag text-rausch"><%= t("reverse_what_if.section_eyebrow") %></p>
    <h2 class="type-display-xl mt-3" style="max-width:920px;"><%= t("reverse_what_if.section_title") %></h2>
    <p class="type-body-md text-body-airbnb mt-5" style="max-width:760px;"><%= t("reverse_what_if.section_lead") %></p>

    <div class="mt-12">
      <%# SHAP 색 재맵핑은 ISS-013에서 처리 — partial 내부는 보존 %>
      <%= render "shared/reverse_what_if_demo" %>
    </div>
  </div>
</section>

<%# Step detail blocks %>
<section class="surface-soft section-pad">
  <div class="wrap space-y-8">
    <% t("workflow.steps").each_with_index do |step, i| %>
      <% is_core = step[:sub].to_s.include?("★") %>
      <div class="grid grid-cols-1 md:grid-cols-[80px_1fr] gap-6 card-airbnb" style="padding:36px; <%= 'border-color: var(--color-rausch);' if is_core %>">
        <div class="font-mono type-uppercase-tag <%= is_core ? 'text-rausch' : 'text-muted-airbnb' %>" style="font-size:14px; letter-spacing:0.12em;">
          STEP / <%= format('%02d', i + 1) %>
        </div>
        <div>
          <div class="flex items-baseline gap-3 flex-wrap">
            <h3 class="type-display-sm"><%= step[:title] %></h3>
            <div class="font-mono type-body-sm <%= is_core ? 'text-rausch' : 'text-muted-airbnb' %>"><%= step[:sub] %></div>
          </div>
          <p class="type-body-md text-body-airbnb mt-3" style="line-height:1.65;"><%= step[:desc] %></p>
        </div>
      </div>
    <% end %>
  </div>
</section>

<%# ============ FAQ (FAQPage JSON-LD 동반) ============ %>
<% if faq_items.is_a?(Array) && faq_items.any? %>
<section id="faq" class="surface-canvas section-pad">
  <div class="wrap">
    <p class="type-uppercase-tag text-rausch"><%= t("faq.section_eyebrow") %></p>
    <h2 class="type-display-xl mt-3" style="max-width:920px;"><%= t("faq.section_title") %></h2>

    <div class="mt-10 space-y-4" itemscope itemtype="https://schema.org/FAQPage">
      <% faq_items.each do |item| %>
        <details
          class="card-airbnb"
          style="padding:20px 24px;"
          itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
          <summary class="cursor-pointer type-title-md" itemprop="name">
            <%= item[:q] %>
          </summary>
          <div class="mt-4 type-body-md text-body-airbnb"
               style="line-height:1.7;"
               itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
            <div itemprop="text"><%= item[:a] %></div>
          </div>
        </details>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<section class="section-dark section-pad-compact text-center">
  <div class="wrap">
    <h2 class="h-section" style="color:#fff; max-width:760px; margin:0 auto;">
      <%= I18n.locale == :ko ? "지금 5단계를 직접 체험해보세요." : "Experience the 5 steps yourself." %>
    </h2>
    <div class="mt-8">
      <%= link_to t("site.hero.cta_demo"), demo_path(locale: I18n.locale), class: "btn-rausch" %>
    </div>
  </div>
</section>
