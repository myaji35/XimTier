<% content_for :title, "#{t('why_not_llm.h1')} — #{t('site.brand')}" %>

<%# 01 Hero (Dark) %>
<section class="section-dark section-pad">
  <div class="wrap" style="max-width:920px;">
    <div class="eyebrow"><span class="dot"></span><%= t("why_not_llm.eyebrow") %></div>
    <h1 class="h-section mt-3" style="color:#fff; max-width:780px;"><%= t("why_not_llm.h1") %></h1>
    <p class="lead mt-5" style="color:#a7b1c7; max-width:720px;"><%= t("why_not_llm.lead") %></p>

    <ul class="mt-9 grid grid-cols-1 md:grid-cols-2" style="gap:10px;">
      <% t("why_not_llm.not_pattern").each_with_index do |line, i| %>
        <li class="text-[14px] font-mono"
            style="padding:10px 14px; border-radius:10px;
                   background:<%= i == 3 ? 'rgba(0,200,200,0.12)' : 'rgba(255,255,255,0.04)' %>;
                   border:1px solid <%= i == 3 ? 'rgba(0,200,200,0.35)' : 'rgba(255,255,255,0.08)' %>;
                   color:<%= i == 3 ? '#00C8C8' : '#e6e8f0' %>;">
          <%= line %>
        </li>
      <% end %>
    </ul>
  </div>
</section>

<%# 02 4-row 매트릭스 (Light) %>
<section class="section-light section-pad">
  <div class="wrap" style="max-width:1080px;">
    <div class="eyebrow"><span class="dot"></span>MATRIX</div>
    <h2 class="h-section mt-3"><%= t("why_not_llm.matrix_title") %></h2>

    <div class="mt-10 overflow-x-auto">
      <table class="w-full" style="border-collapse:separate; border-spacing:0; min-width:720px; font-size:13px;">
        <thead>
          <tr>
            <% cols = t("why_not_llm.matrix_cols") %>
            <% [:tool, :attribution, :reverse, :proof, :onprem].each_with_index do |k, i| %>
              <th class="text-left p-3 font-mono text-[11px]" style="background:#F2F4F7; color:#697386; letter-spacing:0.12em;
                  border:1px solid #e5e9f0; <%= i == 0 ? '' : 'border-left:0;' %>"><%= cols[k] %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% t("why_not_llm.rows").each_with_index do |row, ridx| %>
            <% is_highlight = ridx == t("why_not_llm.rows_highlight") %>
            <% bg = is_highlight ? "rgba(0,200,200,0.06)" : "#fff" %>
            <% color = is_highlight ? "#0B132D" : "#475467" %>
            <% weight = is_highlight ? "700" : "500" %>
            <tr>
              <td class="p-3" style="background:<%= bg %>; color:#0B132D; font-weight:<%= weight %>; border-left:1px solid #e5e9f0; border-bottom:1px solid #e5e9f0;"><%= row[:tool] %></td>
              <td class="p-3" style="background:<%= bg %>; color:<%= color %>; border-bottom:1px solid #e5e9f0;"><%= row[:attribution] %></td>
              <td class="p-3" style="background:<%= bg %>; color:<%= color %>; font-weight:<%= weight %>; border-bottom:1px solid #e5e9f0;"><%= row[:reverse] %></td>
              <td class="p-3" style="background:<%= bg %>; color:<%= color %>; border-bottom:1px solid #e5e9f0;"><%= row[:proof] %></td>
              <td class="p-3" style="background:<%= bg %>; color:<%= color %>; border-right:1px solid #e5e9f0; border-bottom:1px solid #e5e9f0;"><%= row[:onprem] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<%# 03 두 적 (Tinted) %>
<section class="section-tinted section-pad">
  <div class="wrap" style="max-width:1080px;">
    <div class="eyebrow"><span class="dot"></span>ENEMIES</div>
    <h2 class="h-section mt-3"><%= t("why_not_llm.enemies_title") %></h2>

    <div class="mt-10 grid grid-cols-1 md:grid-cols-2" style="gap:18px;">
      <div class="rounded-[12px] p-6" style="background:#fff; border:1px solid #e5e9f0;">
        <div class="font-mono text-[11px]" style="color:#EF4444; letter-spacing:0.14em;">// ENEMY 01</div>
        <h3 class="h-card mt-2"><%= t("why_not_llm.enemy1_label") %></h3>
        <p class="mt-3 text-[14px]" style="color:#475467; line-height:1.65;"><%= t("why_not_llm.enemy1_body") %></p>
      </div>
      <div class="rounded-[12px] p-6" style="background:#fff; border:1px solid #e5e9f0;">
        <div class="font-mono text-[11px]" style="color:#F59E0B; letter-spacing:0.14em;">// ENEMY 02</div>
        <h3 class="h-card mt-2"><%= t("why_not_llm.enemy2_label") %></h3>
        <p class="mt-3 text-[14px]" style="color:#475467; line-height:1.65;"><%= t("why_not_llm.enemy2_body") %></p>
      </div>
    </div>
  </div>
</section>

<%# 04 Moat (Dark) %>
<section class="section-dark section-pad">
  <div class="wrap" style="max-width:1080px;">
    <div class="eyebrow"><span class="dot"></span>MOAT</div>
    <h2 class="h-section mt-3" style="color:#fff;"><%= t("why_not_llm.moat_title") %></h2>

    <div class="mt-10 grid grid-cols-1 md:grid-cols-2" style="gap:16px;">
      <% t("why_not_llm.moats").each_with_index do |m, i| %>
        <div class="card-dark">
          <div class="flex items-start" style="gap:14px;">
            <div class="font-mono text-[11px]" style="color:#00C8C8; letter-spacing:0.14em;">0<%= i + 1 %></div>
            <div class="flex-1">
              <h3 class="h-card" style="color:#fff;"><%= m[:label] %></h3>
              <p class="mt-2 text-[13px]" style="color:#a7b1c7; line-height:1.65;"><%= m[:body] %></p>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-12 flex flex-wrap" style="gap:14px;">
      <%= link_to t("why_not_llm.cta_demo"),  how_it_works_path(locale: I18n.locale, anchor: "reverse-what-if-demo"), class: "btn btn-grad" %>
      <%= link_to t("why_not_llm.cta_cases"), use_cases_path(locale: I18n.locale), class: "btn btn-ghost" %>
    </div>
  </div>
</section>
