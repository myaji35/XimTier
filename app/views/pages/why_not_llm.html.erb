<% content_for :title, "#{t('why_not_llm.h1')} — #{t('site.brand')}" %>

<%# 01 Hero (Canvas) %>
<section class="surface-canvas section-pad">
  <div class="wrap" style="max-width:920px;">
    <p class="type-uppercase-tag text-rausch"><%= t("why_not_llm.eyebrow") %></p>
    <h1 class="type-display-xl mt-3" style="max-width:780px;"><%= safe_join(t("why_not_llm.h1").split(". ", 2).map { |s| s.end_with?(".") ? s : "#{s}." }, tag.br) %></h1>
    <p class="type-body-md text-body-airbnb mt-5" style="max-width:720px;"><%= t("why_not_llm.lead") %></p>

    <ul class="mt-9 grid grid-cols-1 md:grid-cols-2" style="gap:10px;">
      <% t("why_not_llm.not_pattern").each_with_index do |line, i| %>
        <li class="type-body-sm font-mono <%= i == 3 ? 'text-rausch border-hairline' : 'text-body-airbnb border-hairline-soft' %>"
            style="padding:10px 14px; border-radius:10px; background: var(--color-surface-soft);">
          <%= line %>
        </li>
      <% end %>
    </ul>
  </div>
</section>

<%# 02 4-row 매트릭스 (Canvas) %>
<section class="surface-soft section-pad">
  <div class="wrap" style="max-width:1080px;">
    <p class="type-uppercase-tag text-rausch">MATRIX</p>
    <h2 class="type-display-xl mt-3"><%= t("why_not_llm.matrix_title") %></h2>

    <div class="mt-10 overflow-x-auto">
      <table class="w-full" style="border-collapse:separate; border-spacing:0; min-width:720px; font-size:13px;">
        <thead>
          <tr>
            <% cols = t("why_not_llm.matrix_cols") %>
            <% [:tool, :attribution, :reverse, :proof, :onprem].each_with_index do |k, i| %>
              <th class="text-left p-3 font-mono type-uppercase-tag text-muted-airbnb border-hairline <%= 'border-l-0' if i > 0 %>"
                  style="background: var(--color-surface-soft);"><%= cols[k] %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% t("why_not_llm.rows").each_with_index do |row, ridx| %>
            <% is_highlight = ridx == t("why_not_llm.rows_highlight") %>
            <% body_class = is_highlight ? "text-ink-airbnb font-bold" : "text-body-airbnb" %>
            <% bg_style = is_highlight ? "background: rgba(255,56,92,0.06);" : "background: var(--color-canvas);" %>
            <tr>
              <td class="p-3 text-ink-airbnb font-semibold border-b-hairline" style="<%= bg_style %> border-left:1px solid var(--color-hairline-soft);"><%= row[:tool] %></td>
              <td class="p-3 <%= body_class %> border-b-hairline" style="<%= bg_style %>"><%= row[:attribution] %></td>
              <td class="p-3 <%= body_class %> border-b-hairline" style="<%= bg_style %>"><%= row[:reverse] %></td>
              <td class="p-3 <%= body_class %> border-b-hairline" style="<%= bg_style %>"><%= row[:proof] %></td>
              <td class="p-3 <%= body_class %> border-b-hairline" style="<%= bg_style %> border-right:1px solid var(--color-hairline-soft);"><%= row[:onprem] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<%# 03 두 적 (Canvas) %>
<section class="surface-canvas section-pad">
  <div class="wrap" style="max-width:1080px;">
    <p class="type-uppercase-tag text-rausch">ENEMIES</p>
    <h2 class="type-display-xl mt-3"><%= t("why_not_llm.enemies_title") %></h2>

    <div class="mt-10 grid grid-cols-1 md:grid-cols-2" style="gap:18px;">
      <div class="card-airbnb">
        <p class="font-mono type-uppercase-tag text-rausch">// ENEMY 01</p>
        <h3 class="type-display-sm mt-2"><%= t("why_not_llm.enemy1_label") %></h3>
        <p class="type-body-sm text-body-airbnb mt-3" style="line-height:1.65;"><%= t("why_not_llm.enemy1_body") %></p>
      </div>
      <div class="card-airbnb">
        <p class="font-mono type-uppercase-tag text-rausch">// ENEMY 02</p>
        <h3 class="type-display-sm mt-2"><%= t("why_not_llm.enemy2_label") %></h3>
        <p class="type-body-sm text-body-airbnb mt-3" style="line-height:1.65;"><%= t("why_not_llm.enemy2_body") %></p>
      </div>
    </div>
  </div>
</section>

<%# 04 Moat (Canvas) %>
<section class="surface-soft section-pad">
  <div class="wrap" style="max-width:1080px;">
    <p class="type-uppercase-tag text-rausch">MOAT</p>
    <h2 class="type-display-xl mt-3"><%= t("why_not_llm.moat_title") %></h2>

    <div class="mt-10 grid grid-cols-1 md:grid-cols-2" style="gap:16px;">
      <% t("why_not_llm.moats").each_with_index do |m, i| %>
        <div class="card-airbnb">
          <div class="flex items-start" style="gap:14px;">
            <div class="font-mono type-uppercase-tag text-rausch">0<%= i + 1 %></div>
            <div class="flex-1">
              <h3 class="type-display-sm"><%= m[:label] %></h3>
              <p class="type-body-sm text-body-airbnb mt-2" style="line-height:1.65;"><%= m[:body] %></p>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-12 flex flex-wrap" style="gap:14px;">
      <%= link_to t("why_not_llm.cta_demo"),  how_it_works_path(locale: I18n.locale, anchor: "reverse-what-if-demo"), class: "btn-rausch" %>
      <%= link_to t("why_not_llm.cta_cases"), use_cases_path(locale: I18n.locale), class: "btn-secondary-airbnb" %>
    </div>
  </div>
</section>
