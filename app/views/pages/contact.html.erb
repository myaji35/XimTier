<% content_for :title, "#{t('contact.h1')} — #{t('site.brand')}" %>
<% @inquiry ||= ContactInquiry.new %>

<% if TurnstileVerifier.enabled? %>
  <% content_for :head do %>
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <% end %>
<% end %>

<section class="surface-canvas section-pad">
  <div class="wrap" style="max-width:760px;">
    <p class="type-uppercase-tag text-rausch"><%= t("contact.eyebrow") %></p>
    <h1 class="type-display-xl mt-3"><%= t("contact.h1") %></h1>
    <p class="type-body-md text-body-airbnb mt-5"><%= t("contact.lead") %></p>

    <% if flash[:notice] %>
      <div class="mt-8 p-5 card-airbnb" style="border-color: var(--color-rausch);">
        <p class="type-body-md text-ink-airbnb"><%= flash[:notice] %></p>
      </div>
    <% end %>

    <%= form_with model: @inquiry, url: contact_path(locale: I18n.locale), local: true, class: "mt-10 space-y-5" do |f| %>
      <% if @inquiry.errors.any? %>
        <div class="p-4 card-airbnb" style="border-color: var(--color-rausch);">
          <ul class="list-disc list-inside type-body-sm text-rausch">
            <% @inquiry.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# Honeypot — bots fill this %>
      <div style="position:absolute; left:-9999px;" aria-hidden="true">
        <label>Website (leave empty)<input type="text" name="website" tabindex="-1" autocomplete="off"></label>
      </div>

      <div>
        <%= f.label :name, t("contact.form.name"), class: "block type-body-sm font-semibold text-ink-airbnb mb-2" %>
        <%= f.text_field :name, required: true, maxlength: 100,
              class: "w-full px-4 py-3 rounded-[10px] border-hairline type-body-md text-ink-airbnb",
              style: "background: var(--color-canvas);" %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div>
          <%= f.label :email, t("contact.form.email"), class: "block type-body-sm font-semibold text-ink-airbnb mb-2" %>
          <%= f.email_field :email, required: true,
                class: "w-full px-4 py-3 rounded-[10px] border-hairline type-body-md text-ink-airbnb",
                style: "background: var(--color-canvas);" %>
        </div>
        <div>
          <%= f.label :company, t("contact.form.company"), class: "block type-body-sm font-semibold text-ink-airbnb mb-2" %>
          <%= f.text_field :company, maxlength: 100,
                class: "w-full px-4 py-3 rounded-[10px] border-hairline type-body-md text-ink-airbnb",
                style: "background: var(--color-canvas);" %>
        </div>
      </div>

      <div>
        <%= f.label :industry, t("contact.form.industry"), class: "block type-body-sm font-semibold text-ink-airbnb mb-2" %>
        <%= f.select :industry,
              ContactInquiry.industries.keys.map { |k| [t("contact.industries.#{k}"), k] },
              {},
              class: "w-full px-4 py-3 rounded-[10px] border-hairline type-body-md text-ink-airbnb",
              style: "background: var(--color-canvas);" %>
      </div>

      <div>
        <%= f.label :message, t("contact.form.message"), class: "block type-body-sm font-semibold text-ink-airbnb mb-2" %>
        <%= f.text_area :message, required: true, rows: 5, maxlength: 5000,
              class: "w-full px-4 py-3 rounded-[10px] border-hairline type-body-md text-ink-airbnb",
              style: "background: var(--color-canvas);" %>
      </div>

      <label class="flex items-start gap-3 type-body-sm text-body-airbnb">
        <input type="checkbox" name="contact_inquiry[consent]" value="1" required style="margin-top:4px;">
        <span><%= t("contact.form.consent") %></span>
      </label>

      <% if TurnstileVerifier.enabled? %>
        <div class="cf-turnstile" data-sitekey="<%= TurnstileVerifier.site_key %>" data-theme="light"></div>
      <% end %>

      <div class="pt-2">
        <%= f.submit t("contact.form.submit"), class: "btn-rausch", style: "cursor:pointer;" %>
      </div>
    <% end %>
  </div>
</section>
