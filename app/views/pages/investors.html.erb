<% content_for :title, "#{t('investors.h1')} — #{t('site.brand')}" %>

<section class="section-dark section-pad">
  <div class="wrap">
    <div class="eyebrow"><span class="dot"></span><%= t("investors.eyebrow") %></div>
    <h1 class="h-section mt-3" style="color:#fff; max-width:920px;"><%= t("investors.h1") %></h1>
    <p class="lead mt-5" style="color:#a7b1c7; max-width:760px;"><%= t("investors.lead") %></p>

    <%# Ask + Use of funds %>
    <div class="mt-14 grid grid-cols-1 md:grid-cols-[1fr_1.4fr]" style="gap:32px;">
      <div class="card-dark" style="padding:32px;">
        <div class="font-mono text-[11px]" style="color:#00C8C8; letter-spacing:0.14em;">// ASK</div>
        <div class="mt-3 text-[44px] font-bold text-brand-grad" style="line-height:1;"><%= t("investors.ask.amount") %></div>
        <div class="mt-3 text-[14px]" style="color:#a7b1c7;">
          <%= t("investors.ask.stage") %> · <%= t("investors.ask.equity") %>
        </div>
      </div>

      <div class="card-dark" style="padding:32px;">
        <div class="font-mono text-[11px]" style="color:#00C8C8; letter-spacing:0.14em;">// <%= t("investors.use_of_funds_title").upcase %></div>
        <div class="mt-4 space-y-3">
          <% t("investors.use_of_funds").each do |row| %>
            <div class="grid grid-cols-[1fr_auto_auto] gap-4 items-center">
              <div class="text-[14px]" style="color:#e6e8f0;"><%= row[:item] %></div>
              <div class="font-mono text-[13px]" style="color:#00C8C8;"><%= row[:pct] %></div>
              <div class="text-[13px] font-semibold" style="color:#fff;"><%= row[:amount] %></div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <%# Milestones %>
    <h2 class="h-section mt-20" style="color:#fff; font-size:32px;"><%= t("investors.milestones_title") %></h2>
    <div class="mt-8 grid grid-cols-1 md:grid-cols-3" style="gap:20px;">
      <% t("investors.milestones").each_with_index do |m, i| %>
        <div class="card-dark" style="padding:24px;">
          <div class="font-mono text-[12px] font-bold text-brand-grad">M / <%= format('%02d', i + 1) %></div>
          <p class="mt-3 text-[14px]" style="color:#e6e8f0; line-height:1.6;"><%= m %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# IR download form %>
<section id="ir-download" class="section-tinted section-pad-compact">
  <div class="wrap" style="max-width:640px;">
    <div class="eyebrow"><span class="dot"></span><%= t("investors.download_form.title") %></div>
    <p class="lead mt-3" style="color:#475467;"><%= t("investors.download_form.subtitle") %></p>

    <% @download ||= Download.new %>

    <% if params[:sent] %>
      <div class="mt-6 p-5 rounded-[14px]" style="background:#E0F2FE; border:1px solid #0891B2; color:#0E7490;">
        <%= t("investors.flash.success") %>
      </div>
    <% else %>
      <%= form_with model: @download, url: investors_path(locale: I18n.locale), local: true, class: "mt-8 space-y-4" do |f| %>
        <% if @download.errors.any? %>
          <div class="p-4 rounded-[14px]" style="background:#FEF2F2; border:1px solid #FCA5A5; color:#991B1B;">
            <ul class="list-disc list-inside text-[14px]">
              <% @download.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
            </ul>
          </div>
        <% end %>

        <%# Honeypot %>
        <div style="position:absolute; left:-9999px;" aria-hidden="true">
          <label>Website (leave empty)<input type="text" name="website" tabindex="-1" autocomplete="off"></label>
        </div>

        <%= f.hidden_field :asset, value: (I18n.locale == :en ? "ir_deck_en" : "ir_deck_ko") %>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= f.label :name, t("contact.form.name"), class: "block text-[13px] font-medium mb-2", style: "color:#0B132D;" %>
            <%= f.text_field :name, required: true, maxlength: 100,
                  class: "w-full px-4 py-3 rounded-[10px] border text-[15px]",
                  style: "border-color:#e5e9f0; color:#0B132D; background:#fff;" %>
          </div>
          <div>
            <%= f.label :email, t("contact.form.email"), class: "block text-[13px] font-medium mb-2", style: "color:#0B132D;" %>
            <%= f.email_field :email, required: true,
                  class: "w-full px-4 py-3 rounded-[10px] border text-[15px]",
                  style: "border-color:#e5e9f0; color:#0B132D; background:#fff;" %>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= f.label :company, t("contact.form.company"), class: "block text-[13px] font-medium mb-2", style: "color:#0B132D;" %>
            <%= f.text_field :company, maxlength: 100,
                  class: "w-full px-4 py-3 rounded-[10px] border text-[15px]",
                  style: "border-color:#e5e9f0; color:#0B132D; background:#fff;" %>
          </div>
          <div>
            <%= f.label :role, (I18n.locale == :ko ? "직책" : "Role"), class: "block text-[13px] font-medium mb-2", style: "color:#0B132D;" %>
            <%= f.text_field :role, maxlength: 100,
                  class: "w-full px-4 py-3 rounded-[10px] border text-[15px]",
                  style: "border-color:#e5e9f0; color:#0B132D; background:#fff;" %>
          </div>
        </div>

        <%= f.submit t("investors.download_form.submit"), class: "btn btn-grad mt-2", style: "border:0; cursor:pointer;" %>
      <% end %>
    <% end %>
  </div>
</section>
