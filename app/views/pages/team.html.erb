<% content_for :title, "#{t('team.h1')} — #{t('site.brand')}" %>

<section class="section-tinted section-pad">
  <div class="wrap">
    <div class="eyebrow"><span class="dot"></span><%= t("team.eyebrow") %></div>
    <h1 class="h-section mt-3" style="max-width:920px;"><%= t("team.h1") %></h1>
    <p class="lead mt-5" style="color:#475467; max-width:760px;"><%= t("team.lead") %></p>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-2" style="gap:24px;">
      <% %w[ceo cto].each do |key| %>
        <% m = t("team.members.#{key}") %>
        <article class="card" style="padding:36px;">
          <div class="flex items-center gap-4">
            <div class="w-16 h-16 rounded-full flex items-center justify-center text-[24px] font-bold text-white"
                 style="background:linear-gradient(135deg,#2563EB,#00C8C8);">
              <%= m[:initial] %>
            </div>
            <div>
              <div class="h-card" style="color:#0B132D;"><%= m[:name] %></div>
              <div class="font-mono text-[12px] mt-1" style="color:#2563EB; letter-spacing:0.12em;"><%= m[:role] %></div>
            </div>
          </div>
          <ul class="mt-6 space-y-2">
            <% m[:bullets].each do |b| %>
              <li class="text-[14px] flex items-start gap-2" style="color:#475467; line-height:1.6;">
                <span style="color:#2563EB; margin-top:2px;">▸</span><span><%= b %></span>
              </li>
            <% end %>
          </ul>
        </article>
      <% end %>
    </div>

    <%# Team strengths %>
    <h2 class="h-section mt-20" style="font-size:32px;"><%= t("team.strengths_title") %></h2>
    <div class="mt-8 grid grid-cols-1 md:grid-cols-3" style="gap:20px;">
      <% %w[problem_owner lean advisors].each do |key| %>
        <% s = t("team.strengths.#{key}") %>
        <div class="card" style="padding:24px;">
          <div class="h-card" style="color:#0B132D; font-size:18px;"><%= s[:title] %></div>
          <p class="mt-3 text-[14px]" style="color:#475467; line-height:1.6;"><%= s[:body] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>
