<% content_for :title, "#{t('use_cases.h1')} — #{t('site.brand')}" %>

<section class="section-dark section-pad">
  <div class="wrap">
    <div class="eyebrow"><span class="dot"></span><%= t("use_cases.eyebrow") %></div>
    <h1 class="h-section mt-3" style="color:#fff; max-width:920px;"><%= t("use_cases.h1") %></h1>
    <p class="lead mt-5" style="color:#a7b1c7; max-width:760px;"><%= t("use_cases.lead") %></p>

    <% case_study_keys = %w[manufacturing hospital public smart_city] %>
    <div class="mt-14 grid grid-cols-1 md:grid-cols-2" style="gap:24px;">
      <% %w[manufacturing hospital public smart_city finance retail logistics energy education telecom].each do |key| %>
        <% c = t("use_cases.cards.#{key}") %>
        <article class="card-dark">
          <div class="flex items-start gap-4">
            <div class="shrink-0 w-12 h-12 rounded-lg flex items-center justify-center"
                 style="background:linear-gradient(135deg, rgba(37,99,235,0.2), rgba(0,200,200,0.18)); border:1px solid rgba(0,200,200,0.35); color:#00C8C8;">
              <%= render IconComponent.new(name: c[:icon], size: 22) %>
            </div>
            <div class="flex-1">
              <div class="font-mono text-[11px]" style="color:#00C8C8; letter-spacing:0.14em;">// <%= c[:persona].to_s.upcase %></div>
              <h3 class="h-card mt-2" style="color:#fff;"><%= c[:title] %></h3>
              <p class="mt-3 text-[14px]" style="color:#a7b1c7; line-height:1.65;"><%= c[:body] %></p>
              <ul class="mt-4 space-y-1.5">
                <% (c[:outcomes] || []).each do |outcome| %>
                  <li class="text-[13px] flex items-start gap-2" style="color:#e6e8f0;">
                    <span style="color:#00C8C8;">→</span><span><%= outcome %></span>
                  </li>
                <% end %>
              </ul>
              <div class="mt-5">
                <% if case_study_keys.include?(key) %>
                  <% slug = key.tr("_", "-") %>
                  <%= link_to (I18n.locale == :ko ? "케이스 상세 보기 →" : "Read case study →"),
                        case_study_path(locale: I18n.locale, slug: slug),
                        class: "text-[13px] font-semibold", style: "color:#00C8C8;" %>
                <% else %>
                  <%= link_to (I18n.locale == :ko ? "이 산업으로 데모 신청 →" : "Request a demo for this industry →"),
                        demo_path(locale: I18n.locale),
                        class: "text-[13px] font-semibold", style: "color:#00C8C8;" %>
                <% end %>
              </div>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  </div>
</section>

<section class="section-light section-pad-compact text-center">
  <div class="wrap">
    <h2 class="h-section" style="max-width:760px; margin:0 auto;">
      <%= I18n.locale == :ko ? "당신의 산업에 적용한다면?" : "What if it applied to your industry?" %>
    </h2>
    <div class="mt-8 flex justify-center flex-wrap" style="gap:12px;">
      <%= link_to t("site.hero.cta_demo"), demo_path(locale: I18n.locale), class: "btn btn-grad" %>
      <%= link_to t("site.nav.contact"), contact_path(locale: I18n.locale), class: "btn btn-ghost" %>
    </div>
  </div>
</section>
