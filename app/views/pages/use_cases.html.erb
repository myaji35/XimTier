<% content_for :title, "#{t('use_cases.h1')} — #{t('site.brand')}" %>

<section class="surface-canvas section-pad">
  <div class="wrap">
    <p class="type-uppercase-tag text-rausch"><%= t("use_cases.eyebrow") %></p>
    <h1 class="type-display-xl mt-3" style="max-width:920px;"><%= t("use_cases.h1") %></h1>
    <p class="type-body-md text-body-airbnb mt-5" style="max-width:760px;"><%= t("use_cases.lead") %></p>

    <%# ROI 1줄 (CI 레터팩 톤) %>
    <div class="mt-6 inline-block font-mono airbnb-floating-badge" style="letter-spacing:0.08em; padding:8px 14px;">
      <span class="text-rausch"><%= t("use_cases.roi_line") %></span>
    </div>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-2" style="gap:24px;">
      <% %w[manufacturing hospital public smart_city finance retail logistics energy education telecom].each do |key| %>
        <% c = t("use_cases.cards.#{key}") %>
        <article class="card-airbnb shadow-card-hover">
          <div class="flex items-start gap-4">
            <div class="shrink-0 w-12 h-12 rounded-lg flex items-center justify-center border-hairline text-rausch">
              <%= render IconComponent.new(name: c[:icon], size: 22) %>
            </div>
            <div class="flex-1">
              <div class="font-mono type-uppercase-tag text-rausch">// <%= c[:persona].to_s.upcase %></div>
              <% if c[:ai_role].present? %>
                <div class="mt-1 inline-block font-mono airbnb-new-tag"
                     style="background: var(--color-canvas); color: var(--color-rausch); border:1px solid var(--color-rausch); padding:2px 8px; letter-spacing:0.08em;">
                  <%= c[:ai_role] %>
                </div>
              <% end %>
              <h3 class="type-display-sm mt-2"><%= c[:title] %></h3>
              <p class="type-body-sm text-body-airbnb mt-3" style="line-height:1.65;"><%= c[:body] %></p>
              <ul class="mt-4 space-y-1.5">
                <% (c[:outcomes] || []).each do |outcome| %>
                  <li class="type-body-sm text-ink-airbnb flex items-start gap-2">
                    <span class="text-rausch">→</span><span><%= outcome %></span>
                  </li>
                <% end %>
              </ul>
              <% slug = key.tr("_", "-") %>
              <div class="mt-5">
                <%= link_to (I18n.locale == :ko ? "케이스 상세 보기 →" : "Read case study →"),
                      case_study_path(locale: I18n.locale, slug: slug),
                      class: "type-body-sm font-semibold text-rausch hover:underline" %>
              </div>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  </div>
</section>

<section class="surface-soft section-pad-compact text-center">
  <div class="wrap">
    <h2 class="type-display-xl" style="max-width:760px; margin:0 auto;">
      <%= I18n.locale == :ko ? "당신의 산업에 적용한다면?" : "What if it applied to your industry?" %>
    </h2>
    <div class="mt-8 flex justify-center flex-wrap" style="gap:12px;">
      <%= link_to t("site.hero.cta_demo"), demo_path(locale: I18n.locale), class: "btn-rausch" %>
      <%= link_to t("site.nav.contact"), contact_path(locale: I18n.locale), class: "btn-secondary-airbnb" %>
    </div>
  </div>
</section>
