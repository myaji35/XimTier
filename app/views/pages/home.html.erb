<% content_for :title, "#{t('site.brand')} — #{t('site.positioning')}" %>

<%= render "shared/mini_nav" %>

<%# ============ 01 Hero (Deep Navy) ============ %>
<section class="section-dark relative overflow-hidden" style="padding:140px 0 120px;">
  <%# radial blue/teal glow %>
  <div class="absolute inset-0 pointer-events-none" style="
      background:
        radial-gradient(900px 500px at 85% 30%, rgba(0,200,200,0.14), transparent 60%),
        radial-gradient(800px 600px at 10% 80%, rgba(37,99,235,0.22), transparent 60%);
    "></div>

  <div class="wrap relative grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr]" style="gap:60px; align-items:center;">
    <%# Left: Headline + CTA + 4 pillars %>
    <div>
      <div class="eyebrow"><span class="dot"></span><%= t("site.hero.eyebrow") %></div>

      <h1 class="h-display" style="color:#fff; word-break:keep-all; overflow-wrap:break-word;">
        <%= t("site.hero.headline_top") %><br>
        <span class="text-brand-grad"><%= t("site.hero.headline_bottom") %></span>
      </h1>

      <p class="lead mt-6" style="color:#a7b1c7; max-width:560px;">
        <%= t("site.hero.subhead") %>
      </p>

      <div class="mt-9 flex flex-wrap items-center" style="gap:24px;">
        <%= link_to t("site.hero.cta_demo"), demo_path(locale: I18n.locale),
              class: "btn btn-grad cta-primary",
              style: "padding:16px 28px; font-size:15px; font-weight:600; box-shadow:0 12px 28px -8px rgba(0,200,200,0.4);" %>
        <%= link_to t("site.hero.cta_ir"),   investors_path(locale: I18n.locale),
              class: "text-[14px] font-semibold cta-secondary",
              style: "color:#a7b1c7;" %>
      </div>

      <%# 4 Pillars %>
      <div class="mt-14 grid grid-cols-2 md:grid-cols-4" style="gap:14px;">
        <% t("site.hero.pillars").each do |pillar| %>
          <div class="rounded-[12px] p-4" style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08);">
            <div class="font-mono text-[10px]" style="color:#00C8C8; letter-spacing:0.12em;">PILLAR</div>
            <div class="mt-1 text-[14px] font-semibold" style="color:#fff;"><%= pillar[:label] %></div>
            <div class="mt-0.5 text-[12px]" style="color:#8a94ac;"><%= pillar[:desc] %></div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Right: X-mark + floating data chips %>
    <div class="relative hidden lg:block" style="min-height:440px;">
      <%# Giant X-mark glow %>
      <div class="absolute" style="left:50%; top:50%; transform:translate(-50%,-50%); width:280px; height:280px; opacity:0.95;">
        <svg viewBox="0 0 64 64" width="100%" height="100%"><use href="#x-mark-light"/></svg>
      </div>

      <%# Floating data chips %>
      <% t("site.hero.chips").each_with_index do |chip, i| %>
        <% positions = ["left:8%; top:8%;", "right:6%; top:18%;", "left:4%; bottom:18%;", "right:8%; bottom:8%;"] %>
        <div class="absolute inline-flex items-center font-mono text-[12px] float-chip float-chip-<%= i + 1 %>" style="
              <%= positions[i] %>
              gap:8px;
              padding:10px 14px;
              border-radius:999px;
              background: rgba(255,255,255,0.06);
              border: 1px solid rgba(255,255,255,0.12);
              backdrop-filter: blur(12px);
              color: #e6e8f0;
            ">
          <span style="width:8px; height:8px; border-radius:50%; background:linear-gradient(135deg,#2563EB,#00C8C8);"></span>
          <span><%= chip[:label] %> <span style="color:#00C8C8;"><%= chip[:value] %></span></span>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ============ 02 Trust signal strip (출처·검증) ============ %>
<section class="section-dark" style="padding:14px 0; border-top:1px solid rgba(255,255,255,0.08); background:#060c1f;">
  <div class="wrap flex items-center justify-between flex-wrap" style="gap:24px;">
    <div class="font-mono text-[10px]" style="color:#00C8C8; letter-spacing:0.18em;">// <%= t("site.trust_strip.label").upcase %></div>
    <div class="flex flex-wrap items-center" style="gap:28px;">
      <% t("site.trust_strip.items").each do |it| %>
        <div class="flex items-baseline" style="gap:8px;">
          <span class="font-mono text-[10px]" style="color:#697386; letter-spacing:0.12em; text-transform:uppercase;"><%= it[:label] %></span>
          <span class="text-[12px] font-semibold" style="color:#e6e8f0;"><%= it[:value] %></span>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ============ 03 Fear-fact KPI 거대 (€35M / D-Day / 100%) ============ %>
<section id="fear" class="section-dark" style="padding:44px 0; border-top:1px solid rgba(255,255,255,0.08); border-bottom:1px solid rgba(255,255,255,0.08); background:#060c1f;">
  <div class="wrap grid grid-cols-1 md:grid-cols-3" style="gap:32px;">
    <%# 1) EU 벌금 %>
    <div class="flex flex-col" style="padding:0 12px;">
      <div class="font-mono text-[10px]" style="color:#EF4444; letter-spacing:0.18em;">// EU AI ACT</div>
      <div class="mt-3" style="font-size:42px; font-weight:800; line-height:1; color:#fff; letter-spacing:-0.02em;">
        <%= t("site.fear_strip.eu_amount") %>
      </div>
      <div class="mt-3 text-[12px]" style="color:#8a94ac; line-height:1.55;"><%= t("site.fear_strip.eu") %></div>
    </div>
    <%# 2) D-Day %>
    <div class="flex flex-col" style="padding:0 12px;">
      <div class="font-mono text-[10px]" style="color:#F59E0B; letter-spacing:0.18em;">// KR AI ACT</div>
      <div class="mt-3" style="font-size:42px; font-weight:800; line-height:1; color:#fff; letter-spacing:-0.02em;">
        <%= t("site.fear_strip.kr_status") %>
      </div>
      <div class="mt-3 text-[12px]" style="color:#8a94ac; line-height:1.55;"><%= t("site.fear_strip.kr") %></div>
    </div>
    <%# 3) 100% %>
    <div class="flex flex-col" style="padding:0 12px;">
      <div class="font-mono text-[10px]" style="color:#00C8C8; letter-spacing:0.18em;">// AUDIT</div>
      <div class="mt-3" style="font-size:42px; font-weight:800; line-height:1; color:#fff; letter-spacing:-0.02em;">
        <span class="text-brand-grad"><%= t("site.fear_strip.audit_status") %></span>
      </div>
      <div class="mt-3 text-[12px]" style="color:#8a94ac; line-height:1.55;"><%= t("site.fear_strip.audit") %></div>
    </div>
  </div>
</section>

<%# ============ 04 Why Now (Light) ============ %>
<section id="why-now" class="section-light" style="padding:60px 0; border-bottom:1px solid #e5e9f0;">
  <div class="wrap" style="max-width:920px;">
    <div class="eyebrow"><span class="dot"></span><%= t("why_now.eyebrow") %></div>
    <h2 class="h-section mt-3"><%= t("why_now.title") %></h2>
    <p class="lead mt-5" style="color:#475467;"><%= t("why_now.body") %></p>
    <div class="mt-6">
      <a href="/<%= I18n.locale %>/why-not-llm" class="text-[14px] font-semibold" style="color:#2563EB;"><%= t("why_now.cta") %></a>
    </div>
  </div>
</section>

<%# ============ 03 Problem (Light) ============ %>
<section id="problem" class="section-light section-pad">
  <div class="wrap">
    <div class="eyebrow"><span class="dot"></span><%= t("problem.eyebrow") %></div>
    <h2 class="h-section mt-3" style="max-width:920px;"><%= t("problem.h1") %></h2>
    <p class="lead mt-5" style="color:#475467; max-width:760px;"><%= t("problem.lead") %></p>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-3" style="gap:24px;">
      <% %w[data_sovereignty numeric_calc regulation].each do |key| %>
        <% c = t("problem.cards.#{key}") %>
        <%= render CardComponent.new(
              icon: c[:icon],
              eyebrow: c[:eyebrow],
              title: c[:title],
              body: c[:body],
              quote: c[:quote],
              stat_value: c[:stat_value],
              stat_label: c[:stat_label]
            ) %>
      <% end %>
    </div>
  </div>
</section>

<%# ============ 04 Solution (Dark) ============ %>
<section id="solution" class="section-dark section-pad">
  <div class="wrap">
    <div class="eyebrow"><span class="dot"></span><%= t("solution.eyebrow") %></div>
    <h2 class="h-section mt-3" style="color:#fff; max-width:920px;"><%= t("solution.h1") %></h2>
    <p class="lead mt-5" style="color:#a7b1c7; max-width:760px;"><%= t("solution.lead") %></p>

    <blockquote class="mt-10 pl-5" style="border-left:3px solid; border-image:linear-gradient(135deg,#2563EB,#00C8C8) 1; max-width:720px;">
      <p class="text-[18px] italic" style="color:#e6e8f0;">"<%= t("solution.callout") %>"</p>
    </blockquote>

    <%# 5-step workflow %>
    <div class="mt-16">
      <div class="font-mono text-[11px] mb-4" style="color:#00C8C8; letter-spacing:0.14em;">// 5-STEP WORKFLOW</div>
      <%= render WorkflowStepsComponent.new(steps: t("workflow.steps"), tone: :dark) %>
    </div>

    <div class="mt-10">
      <%= link_to t("site.nav.how_it_works") + " →", how_it_works_path(locale: I18n.locale),
            class: "btn btn-ghost" %>
    </div>
  </div>
</section>

<%# ============ 05 Market indicators (Tinted) ============ %>
<section class="section-tinted section-pad-compact">
  <div class="wrap">
    <div class="eyebrow"><span class="dot"></span><%= t("market.eyebrow") %></div>
    <div class="grid grid-cols-1 md:grid-cols-[1fr_1fr] mt-3" style="gap:48px; align-items:end;">
      <h2 class="h-section" style="max-width:560px;"><%= t("market.h1") %></h2>
      <p class="lead" style="color:#475467;"><%= t("market.lead") %></p>
    </div>

    <div class="mt-14 grid grid-cols-2 md:grid-cols-5" style="gap:16px;">
      <% t("market.indicators").each do |ind| %>
        <div class="rounded-[14px] p-5" style="background:#fff; border:1px solid #e5e9f0;">
          <div class="text-[28px] font-bold text-brand-grad" style="line-height:1;"><%= ind[:value] %></div>
          <div class="mt-2 text-[12px]" style="color:#697386;"><%= ind[:label] %></div>
        </div>
      <% end %>
    </div>

    <div class="mt-6 text-center">
      <%= link_to (I18n.locale == :ko ? "이 숫자들의 근거 보기 →" : "How these numbers are derived →"),
            market_path(locale: I18n.locale),
            class: "text-[14px] font-semibold", style: "color:#2563EB;" %>
    </div>
  </div>
</section>

<%# ============ 06 Moat (Light) ============ %>
<section id="moat" class="section-light section-pad">
  <div class="wrap">
    <div class="eyebrow"><span class="dot"></span><%= t("moat.eyebrow") %></div>
    <div class="grid grid-cols-1 md:grid-cols-[1fr_1fr] mt-3" style="gap:48px; align-items:end;">
      <h2 class="h-section" style="max-width:560px;"><%= t("moat.h1") %></h2>
      <p class="lead" style="color:#475467;"><%= t("moat.lead") %></p>
    </div>

    <div class="mt-16">
      <%= render MoatTriangleComponent.new(
            sovereignty: t("moat.triangle.points.sovereignty"),
            regulated:   t("moat.triangle.points.regulated"),
            reverse:     t("moat.triangle.points.reverse")
          ) %>
    </div>

    <blockquote class="mt-12 pl-5" style="border-left:3px solid; border-image:linear-gradient(135deg,#2563EB,#00C8C8) 1; max-width:760px;">
      <p class="text-[16px] italic" style="color:#475467;">"<%= t("moat.callout") %>"</p>
    </blockquote>
  </div>
</section>

<%# ============ 07 CTA strip (Deep Navy) ============ %>
<section id="cta" class="section-dark section-pad-compact relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none" style="
      background: radial-gradient(700px 400px at 50% 50%, rgba(37,99,235,0.22), transparent 60%);
    "></div>
  <div class="wrap relative text-center">
    <h2 class="h-section" style="color:#fff; max-width:760px; margin:0 auto;">
      <%= I18n.locale == :ko ? "비전문가도 5분 안에 의사결정을 끝냅니다." : "Even non-experts finish a decision in 5 minutes." %>
    </h2>
    <div class="mt-8 flex justify-center flex-wrap" style="gap:12px;">
      <%= link_to t("site.hero.cta_demo"), demo_path(locale: I18n.locale),    class: "btn btn-grad" %>
      <%= link_to t("site.nav.contact"),   contact_path(locale: I18n.locale), class: "btn btn-ghost" %>
    </div>
  </div>
</section>
