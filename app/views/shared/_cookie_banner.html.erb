<div data-controller="cookie-banner">
  <div data-cookie-banner-target="banner"
       class="fixed z-50"
       style="bottom: 20px; left: 20px; right: 20px;
              max-width: 540px; margin: 0 auto;
              background: #0B132D; color: #fff;
              padding: 18px 22px; border-radius: 14px;
              box-shadow: 0 20px 40px -10px rgba(11,19,45,0.4);
              transform: translateY(120%); opacity: 0;
              transition: transform 0.3s ease, opacity 0.3s ease;">

    <div class="flex flex-col md:flex-row md:items-center gap-3">
      <div class="flex-1">
        <div class="font-mono text-[10px]" style="color:#00C8C8; letter-spacing:0.14em;">// COOKIES</div>
        <p class="mt-1 text-[13px]" style="color:#e6e8f0; line-height:1.55;">
          <%= I18n.locale == :ko ?
                "XimTier는 필수 쿠키(로그인 세션)와 cookieless 분석만 사용합니다. 추적·광고 쿠키 없음." :
                "XimTier uses only essential cookies (login session) and cookieless analytics. No tracking or advertising cookies." %>
        </p>
      </div>
      <div class="flex items-center gap-2 flex-shrink-0">
        <%= link_to (I18n.locale == :ko ? "자세히" : "Details"),
              "/#{I18n.locale}/privacy",
              class: "text-[12px] underline", style: "color:#a7b1c7;" %>
        <button type="button" data-action="click->cookie-banner#accept"
                class="btn btn-grad"
                style="border:0; cursor:pointer; padding:8px 18px; font-size:13px;">
          <%= I18n.locale == :ko ? "확인" : "Got it" %>
        </button>
      </div>
    </div>
  </div>
</div>
