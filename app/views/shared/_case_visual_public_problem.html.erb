<%# 공공 Problem — 사후 분석만 가능한 정책 데이터 %>
<div class="case-visual">
  <div class="layer grid-bg"></div>
  <div class="layer flex flex-col justify-center" style="padding:32px 36px;">
    <div class="flex items-center justify-between mb-3">
      <span class="label-mono">// YOUTH UNEMPLOYMENT</span>
      <span class="font-mono text-[14px] font-bold" style="color:#EF4444;">4.9%</span>
    </div>

    <%# 시계열 라인 그래프 — 사후 데이터만 %>
    <svg viewBox="0 0 360 140" style="width:100%; height:140px;">
      <defs>
        <linearGradient id="cv-public-area" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%"   stop-color="#EF4444" stop-opacity="0.25"/>
          <stop offset="100%" stop-color="#EF4444" stop-opacity="0"/>
        </linearGradient>
      </defs>
      <%# Grid lines %>
      <line x1="0" y1="35"  x2="360" y2="35"  stroke="#e5e9f0" stroke-width="1"/>
      <line x1="0" y1="70"  x2="360" y2="70"  stroke="#e5e9f0" stroke-width="1"/>
      <line x1="0" y1="105" x2="360" y2="105" stroke="#e5e9f0" stroke-width="1"/>
      <%# Target line %>
      <line x1="0" y1="90" x2="360" y2="90" stroke="#10B981" stroke-width="1.5" stroke-dasharray="4 4"/>
      <text x="320" y="86" fill="#10B981" font-family="JetBrains Mono, monospace" font-size="9">목표 4.0%</text>
      <%# Actual line — 위로 ↑ %>
      <path d="M0,90 L60,82 L120,75 L180,68 L240,62 L300,55 L360,50"
            fill="url(#cv-public-area)"/>
      <path class="cv-public-line"
            d="M0,90 L60,82 L120,75 L180,68 L240,62 L300,55 L360,50"
            stroke="#EF4444" stroke-width="2.5" fill="none"/>
      <circle class="cv-public-dot" cx="120" cy="75" r="4" fill="#EF4444"/>
      <circle class="cv-public-dot" cx="240" cy="62" r="4" fill="#EF4444"/>
      <circle class="cv-public-dot" cx="360" cy="50" r="4" fill="#EF4444"/>
    </svg>

    <div class="mt-3 font-mono text-[10px] text-center" style="color:#697386;">
      매번 사후 분석만 가능 · 정책 시뮬레이션 부재
    </div>
  </div>
</div>
