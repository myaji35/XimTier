<%# 스마트시티 Approach — 통합 IoT + MCP 인터페이스 %>
<div class="case-visual">
  <div class="layer grid-bg"></div>
  <div class="layer flex flex-col justify-center" style="padding:32px 36px;">
    <div class="label-mono mb-3">// UNIFIED IoT GATEWAY</div>

    <%# 큰 통합 그리드 %>
    <div class="grid grid-cols-12 gap-2" style="margin-bottom:18px;">
      <% 36.times do |i| %>
        <span class="cv-iot-dot" style="animation-delay:<%= (i * 0.07).round(2) %>s;"></span>
      <% end %>
    </div>

    <%# Cross-domain KPI 화살표 %>
    <div class="space-y-2">
      <div class="flex items-center gap-2 p-2 rounded-[8px]" style="background:#fff; border:1px solid #e5e9f0;">
        <span class="font-mono text-[10px]" style="color:#697386; width:56px;">교통 −5%</span>
        <span style="color:#00C8C8;">→</span>
        <span class="font-mono text-[10px] font-bold" style="color:#10B981;">에너지 −3.2%</span>
        <span class="font-mono text-[9px] ml-auto" style="color:#697386;">상관 0.78</span>
      </div>
      <div class="flex items-center gap-2 p-2 rounded-[8px]" style="background:#fff; border:1px solid #e5e9f0;">
        <span class="font-mono text-[10px]" style="color:#697386; width:56px;">신호 최적</span>
        <span style="color:#00C8C8;">→</span>
        <span class="font-mono text-[10px] font-bold" style="color:#10B981;">CO₂ −4.1%</span>
        <span class="font-mono text-[9px] ml-auto" style="color:#697386;">±3% 정확도</span>
      </div>
    </div>

    <div class="mt-4 p-2 rounded-[8px] text-center" style="background:linear-gradient(135deg, rgba(37,99,235,0.08), rgba(0,200,200,0.08)); border:1px solid rgba(37,99,235,0.25);">
      <div class="font-mono text-[10px]" style="color:#2563EB; letter-spacing:0.14em;">// MCP-CALLABLE FROM AI AGENTS</div>
    </div>
  </div>
</div>
