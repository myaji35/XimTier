<div class="grid grid-cols-1 md:grid-cols-[1.2fr_1fr] items-center" style="gap:48px;">
  <%# SVG Venn diagram %>
  <div class="flex justify-center">
    <svg viewBox="0 0 480 360" class="w-full" style="max-width:520px;" role="img" aria-label="Market sum-of-adjacent Venn diagram">
      <defs>
        <linearGradient id="venn-di" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%"   stop-color="#2563EB" stop-opacity="0.45"/>
          <stop offset="100%" stop-color="#2563EB" stop-opacity="0.25"/>
        </linearGradient>
        <linearGradient id="venn-xai" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%"   stop-color="#00C8C8" stop-opacity="0.45"/>
          <stop offset="100%" stop-color="#00C8C8" stop-opacity="0.25"/>
        </linearGradient>
        <linearGradient id="venn-prescript" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%"   stop-color="#A855F7" stop-opacity="0.45"/>
          <stop offset="100%" stop-color="#A855F7" stop-opacity="0.25"/>
        </linearGradient>
      </defs>

      <%# DI 큰 원 — 좌상단 %>
      <circle cx="180" cy="160" r="120" fill="url(#venn-di)" stroke="#2563EB" stroke-width="1.5"/>
      <%# XAI 원 — 우상단 %>
      <circle cx="300" cy="160" r="95" fill="url(#venn-xai)" stroke="#00C8C8" stroke-width="1.5"/>
      <%# Prescriptive 원 — 하단 %>
      <circle cx="240" cy="260" r="80" fill="url(#venn-prescript)" stroke="#A855F7" stroke-width="1.5"/>

      <%# Labels — outer %>
      <text x="100" y="80" fill="#2563EB" font-size="13" font-weight="700" font-family="JetBrains Mono, monospace">DI</text>
      <text x="100" y="98" fill="#0B132D" font-size="16" font-weight="700"><%= di[:value] %></text>

      <text x="370" y="100" fill="#0E7490" font-size="13" font-weight="700" font-family="JetBrains Mono, monospace">XAI</text>
      <text x="370" y="118" fill="#0B132D" font-size="16" font-weight="700"><%= xai[:value] %></text>

      <text x="290" y="335" fill="#5B21B6" font-size="13" font-weight="700" font-family="JetBrains Mono, monospace">Prescriptive</text>
      <text x="290" y="353" fill="#0B132D" font-size="16" font-weight="700"><%= prescriptive[:value] %></text>

      <%# Center 중복분 마커 %>
      <circle cx="240" cy="195" r="6" fill="#EF4444"/>
      <text x="252" y="200" fill="#B91C1C" font-size="11" font-weight="700">중복 −$14B</text>
    </svg>
  </div>

  <%# Legend %>
  <div class="space-y-3">
    <div class="p-3 rounded-[10px]" style="background:#fff; border:1px solid #e5e9f0;">
      <div class="flex items-center gap-2">
        <span style="width:14px; height:14px; border-radius:3px; background:linear-gradient(135deg, rgba(37,99,235,0.45), rgba(37,99,235,0.25)); border:1px solid #2563EB;"></span>
        <span class="font-mono text-[11px]" style="color:#2563EB; letter-spacing:0.1em;">DI</span>
        <span class="ml-auto font-bold text-[15px]" style="color:#0B132D;"><%= di[:value] %></span>
      </div>
      <div class="mt-1 text-[12px]" style="color:#475467;"><%= di[:label] %></div>
    </div>

    <div class="p-3 rounded-[10px]" style="background:#fff; border:1px solid #e5e9f0;">
      <div class="flex items-center gap-2">
        <span style="width:14px; height:14px; border-radius:3px; background:linear-gradient(135deg, rgba(0,200,200,0.45), rgba(0,200,200,0.25)); border:1px solid #00C8C8;"></span>
        <span class="font-mono text-[11px]" style="color:#0E7490; letter-spacing:0.1em;">XAI</span>
        <span class="ml-auto font-bold text-[15px]" style="color:#0B132D;"><%= xai[:value] %></span>
      </div>
      <div class="mt-1 text-[12px]" style="color:#475467;"><%= xai[:label] %></div>
    </div>

    <div class="p-3 rounded-[10px]" style="background:#fff; border:1px solid #e5e9f0;">
      <div class="flex items-center gap-2">
        <span style="width:14px; height:14px; border-radius:3px; background:linear-gradient(135deg, rgba(168,85,247,0.45), rgba(168,85,247,0.25)); border:1px solid #A855F7;"></span>
        <span class="font-mono text-[11px]" style="color:#5B21B6; letter-spacing:0.1em;">PRESCRIPTIVE</span>
        <span class="ml-auto font-bold text-[15px]" style="color:#0B132D;"><%= prescriptive[:value] %></span>
      </div>
      <div class="mt-1 text-[12px]" style="color:#475467;"><%= prescriptive[:label] %></div>
    </div>

    <div class="p-3 rounded-[10px] mt-4" style="background:linear-gradient(135deg, rgba(37,99,235,0.08), rgba(0,200,200,0.08)); border:1.5px solid #2563EB;">
      <div class="font-mono text-[11px]" style="color:#2563EB; letter-spacing:0.14em;">// TOTAL</div>
      <div class="mt-1 text-[20px] font-bold text-brand-grad">$81B</div>
      <div class="mt-1 text-[12px]" style="color:#475467;"><%= caption %></div>
    </div>
  </div>
</div>
