<section class="surface-canvas">
  <div class="max-w-6xl mx-auto px-6 py-20 md:py-28">
    <% if eyebrow.present? %>
      <p class="type-uppercase-tag text-rausch mb-4"><%= eyebrow %></p>
    <% end %>

    <h1 class="type-display-xl">
      <%= headline %>
    </h1>

    <% if subhead %>
      <p class="type-body-md text-body-airbnb mt-5 max-w-3xl">
        <%= subhead %>
      </p>
    <% end %>

    <% if actions? %>
      <div class="mt-8 flex flex-wrap gap-3 items-center"><%= actions %></div>
    <% end %>

    <% if indicators? %>
      <div class="mt-14 pt-10 border-t-hairline grid grid-cols-2 md:grid-cols-4 gap-6 text-sm">
        <%= indicators %>
      </div>
    <% end %>
  </div>
</section>
