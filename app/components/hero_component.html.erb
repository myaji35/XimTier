<section class="relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-cyan-500/10 via-slate-950 to-slate-950 pointer-events-none"></div>
  <div class="absolute -top-32 -right-32 w-96 h-96 bg-cyan-500/10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-6 py-24 md:py-32">
    <p class="uppercase tracking-[0.3em] text-xs text-cyan-300/80 mb-6"><%= eyebrow %></p>

    <h1 class="text-4xl md:text-6xl font-bold leading-tight text-slate-50">
      <%= headline %>
    </h1>

    <% if subhead %>
      <p class="mt-6 max-w-3xl text-lg md:text-xl text-slate-300 leading-relaxed">
        <%= subhead %>
      </p>
    <% end %>

    <% if actions? %>
      <div class="mt-10 flex flex-wrap gap-4"><%= actions %></div>
    <% end %>

    <% if indicators? %>
      <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-6 text-sm">
        <%= indicators %>
      </div>
    <% end %>
  </div>
</section>
