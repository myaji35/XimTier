<div class="<%= card_classes %>">
  <% if icon %>
    <div class="w-12 h-12 rounded-lg flex items-center justify-center mb-5"
         style="background:linear-gradient(135deg, rgba(37,99,235,0.10), rgba(0,200,200,0.10)); border:1px solid #e5e9f0; color:#2563EB;">
      <%= render IconComponent.new(name: icon) %>
    </div>
  <% end %>

  <% if eyebrow %>
    <p class="uppercase tracking-[0.2em] text-xs mb-2" style="color:#2563EB; font-weight:600;"><%= eyebrow %></p>
  <% end %>

  <h3 class="text-xl md:text-2xl font-semibold leading-snug" style="color:#0B132D;"><%= title %></h3>

  <% if body %>
    <p class="mt-3 leading-relaxed" style="color:#475467;"><%= body %></p>
  <% end %>

  <% if quote %>
    <blockquote class="mt-5 pl-4 italic text-sm" style="border-left:2px solid #2563EB; color:#697386;">
      "<%= quote %>"
    </blockquote>
  <% end %>

  <% if stat_value %>
    <div class="mt-6 pt-5" style="border-top:1px solid #e5e9f0;">
      <div class="text-2xl font-bold text-brand-grad"><%= stat_value %></div>
      <% if stat_label %>
        <div class="mt-1 text-sm" style="color:#697386; line-height:1.5;"><%= stat_label %></div>
      <% end %>
    </div>
  <% end %>

  <% if content.present? %>
    <div class="mt-4"><%= content %></div>
  <% end %>
</div>
