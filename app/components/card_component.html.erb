<div class="<%= card_classes %>">
  <% if icon %>
    <div class="w-12 h-12 rounded-lg flex items-center justify-center mb-5 border-hairline text-rausch">
      <%= render IconComponent.new(name: icon) %>
    </div>
  <% end %>

  <% if eyebrow %>
    <p class="type-uppercase-tag text-rausch mb-2"><%= eyebrow %></p>
  <% end %>

  <h3 class="type-display-sm"><%= title %></h3>

  <% if body %>
    <p class="type-body-md text-body-airbnb mt-3"><%= body %></p>
  <% end %>

  <% if quote %>
    <blockquote class="type-body-sm text-muted-airbnb mt-5 pl-4 italic border-l border-hairline">
      "<%= quote %>"
    </blockquote>
  <% end %>

  <% if stat_value %>
    <div class="mt-6 pt-5 border-t-hairline">
      <div class="type-display-lg text-rausch"><%= stat_value %></div>
      <% if stat_label %>
        <div class="type-body-sm text-muted-airbnb mt-1"><%= stat_label %></div>
      <% end %>
    </div>
  <% end %>

  <% if content.present? %>
    <div class="mt-4"><%= content %></div>
  <% end %>
</div>
